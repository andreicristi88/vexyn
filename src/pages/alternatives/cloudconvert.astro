---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumbSchema, faqSchema, combineSchemas } from '../../lib/seo';

const title = 'CloudConvert Alternative That Runs in Your Browser';
const description = 'Vexyn is a CloudConvert alternative for image format conversion that runs entirely in your browser. No upload, no daily minute cap, no signup. JPG, PNG, WebP, AVIF supported.';

const faqs = [
  { q: 'Does Vexyn have a developer API like CloudConvert?', a: "No — Vexyn is browser tools only, no API. CloudConvert's API is genuinely good for server-side conversion pipelines. If your use case is automated, build-time, or backend conversion, CloudConvert's API is the right pick. For one-off browser conversion, Vexyn fits." },
  { q: 'What about audio and video conversion?', a: "CloudConvert handles 200+ formats including video (MP4, AVI, MOV) and audio (MP3, WAV, FLAC) conversion. Vexyn currently only does image conversion. We're focused on small, specialized tools rather than a Swiss-army-knife converter." },
  { q: 'How does the speed compare?', a: 'On a modern laptop, Vexyn converts a 5 MB JPEG to WebP in well under 1 second — instant. CloudConvert involves upload + queue + download, so even for a small file the round-trip is 5-15 seconds. For batches, Vexyn pulls clearly ahead because there is no queue.' },
  { q: 'Is CloudConvert better for huge files?', a: 'For files over ~500 MB, yes. Vexyn is bounded by browser memory; CloudConvert can process gigabyte files server-side. Below that threshold, Vexyn is faster and private.' },
];

const schema = combineSchemas(
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Alternatives', url: '/alternatives' },
    { name: 'CloudConvert', url: '/alternatives/cloudconvert' },
  ]),
  faqSchema(faqs),
);
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-10">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <a href="/alternatives" class="hover:text-[color:var(--color-text)]">Alternatives</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">CloudConvert</span>
      </div>

      <p class="text-xs font-medium text-[color:var(--color-text-dim)] uppercase tracking-wider mb-2">Alternative to CloudConvert</p>
      <h1 class="text-4xl font-bold tracking-tight mb-4">A CloudConvert alternative for browser-only conversion</h1>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-3xl leading-relaxed">
        CloudConvert is a mature 200+ format converter with a solid developer API. But every conversion uploads to their cloud and waits in a queue. For everyday image conversion (JPG ↔ PNG ↔ WebP ↔ AVIF), Vexyn does it in your browser instantly.
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/image-converter" class="px-5 py-2.5 rounded-lg bg-[color:var(--color-brand-500)] hover:bg-[color:var(--color-brand-600)] text-white font-medium transition-colors inline-flex items-center gap-2">
          Open Image Converter
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/image-compressor" class="px-5 py-2.5 rounded-lg border border-[color:var(--color-border)] hover:border-[color:var(--color-border-strong)] bg-[color:var(--color-surface)] text-[color:var(--color-text)] font-medium transition-colors">
          Or compress images
        </a>
      </div>
    </header>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-5">Side-by-side</h2>
      <div class="overflow-x-auto rounded-xl border border-[color:var(--color-border)]">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-[color:var(--color-surface)] border-b border-[color:var(--color-border)]">
              <th class="text-left p-4 font-medium text-[color:var(--color-text-mute)]"></th>
              <th class="text-left p-4 font-semibold text-[color:var(--color-brand-400)]">Vexyn</th>
              <th class="text-left p-4 font-semibold">CloudConvert</th>
            </tr>
          </thead>
          <tbody class="text-[color:var(--color-text-mute)]">
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Where files are processed</td>
              <td class="p-4">In your browser</td>
              <td class="p-4">CloudConvert cloud (EU)</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Files uploaded?</td>
              <td class="p-4 text-[color:var(--color-success)]">No</td>
              <td class="p-4">Yes</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Account required</td>
              <td class="p-4 text-[color:var(--color-success)]">No</td>
              <td class="p-4">Optional free / required paid</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Free tier limit</td>
              <td class="p-4 text-[color:var(--color-success)]">Unlimited</td>
              <td class="p-4">25 conversion minutes/day free</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Format coverage</td>
              <td class="p-4">JPG, PNG, WebP, AVIF, HEIC input (image only)</td>
              <td class="p-4 text-[color:var(--color-success)]">200+ formats (image, video, audio, docs)</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Speed (small files)</td>
              <td class="p-4 text-[color:var(--color-success)]">Under 1 sec, no queue</td>
              <td class="p-4">5-15 sec (upload + queue + download)</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Speed (large files)</td>
              <td class="p-4">Limited by RAM (~500 MB ceiling)</td>
              <td class="p-4 text-[color:var(--color-success)]">Handles GBs server-side</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Developer API</td>
              <td class="p-4">No</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes, mature</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Webhooks</td>
              <td class="p-4">No</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Works offline</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes (after first load)</td>
              <td class="p-4">No</td>
            </tr>
            <tr>
              <td class="p-4 text-[color:var(--color-text)] font-medium">Price</td>
              <td class="p-4 text-[color:var(--color-success)]">Free, unlimited</td>
              <td class="p-4">Free tier + $9.50–$33/mo</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-[color:var(--color-text-dim)] mt-3">
        Based on publicly available information from <a href="https://cloudconvert.com" target="_blank" rel="noopener noreferrer" class="hover:text-[color:var(--color-text-mute)] underline">cloudconvert.com</a> as of June 2026. Verify before relying on a specific number.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">When to pick which</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
          <h3 class="font-semibold text-[color:var(--color-brand-400)] mb-2">Pick Vexyn when…</h3>
          <ul class="text-sm text-[color:var(--color-text-mute)] space-y-1.5 list-disc list-inside">
            <li>Converting images interactively, one or many at a time</li>
            <li>Files may contain sensitive data</li>
            <li>You hit CloudConvert's free 25-minute daily cap</li>
            <li>Speed matters — no upload, no queue</li>
            <li>You work offline</li>
          </ul>
        </div>
        <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
          <h3 class="font-semibold mb-2">Pick CloudConvert when…</h3>
          <ul class="text-sm text-[color:var(--color-text-mute)] space-y-1.5 list-disc list-inside">
            <li>You need an API for server-side automation</li>
            <li>Format is video/audio/document (not just image)</li>
            <li>Files exceed browser memory</li>
            <li>You need webhooks or queue management</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">FAQ</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
            <h3 class="font-semibold mb-2">{f.q}</h3>
            <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="p-6 rounded-xl bg-gradient-to-br from-[color:var(--color-brand-500)]/10 to-[color:var(--color-accent-500)]/10 border border-[color:var(--color-brand-500)]/30">
      <h2 class="text-xl font-bold mb-2">Try the converter</h2>
      <p class="text-sm text-[color:var(--color-text-mute)] mb-4">Drop images. Pick a format. Instant — no upload, no queue.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/image-converter" class="px-5 py-2.5 rounded-lg bg-[color:var(--color-brand-500)] hover:bg-[color:var(--color-brand-600)] text-white font-medium transition-colors">Open Image Converter</a>
        <a href="/blog/webp-vs-avif-vs-jpeg-which-format-in-2026" class="px-5 py-2.5 rounded-lg border border-[color:var(--color-border)] hover:border-[color:var(--color-border-strong)] bg-[color:var(--color-surface)] text-[color:var(--color-text)] font-medium transition-colors">Which format to pick →</a>
      </div>
    </section>
  </div>
</BaseLayout>
