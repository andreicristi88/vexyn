# Cloudflare's Workers Autoconfig runs `astro add cloudflare` on every
# build, which pulls @astrojs/cloudflare@^14 — that package only supports
# Astro 7 alpha, while Vexyn is on Astro 6 (stable). Without this flag the
# autoconfig step fails the entire deploy. legacy-peer-deps lets the
# install go through; the adapter is never actually used because
# astro.config.mjs has no `adapter:` reference and output stays static.
legacy-peer-deps=true
