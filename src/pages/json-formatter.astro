---
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonFormatter from '../components/tools/JsonFormatter.svelte';
import { SITE } from '../lib/constants';

const title = 'JSON Formatter';
const description = 'Free JSON formatter, validator and minifier. Runs entirely in your browser — your JSON never gets uploaded. No signup required.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: `${title} — ${SITE.name}`,
  url: `${SITE.url}/json-formatter`,
  description,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  featureList: ['Format JSON', 'Validate JSON', 'Minify JSON', 'Custom indentation', '100% private'],
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-8">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">JSON Formatter</span>
      </div>
      <h1 class="text-4xl font-bold tracking-tight mb-3">JSON Formatter</h1>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-2xl">
        Format, validate, and minify JSON instantly. Everything runs in your browser — your data stays yours.
      </p>
    </header>

    <JsonFormatter client:load />

    <!-- SEO content -->
    <article class="prose mt-16 max-w-3xl">
      <h2 class="text-2xl font-bold mb-4">A private JSON formatter that respects your data</h2>
      <p class="text-[color:var(--color-text-mute)] leading-relaxed mb-6">
        Most online JSON formatters send your data to their servers to process it. That's fine for public JSON, but it's not OK when you're debugging API responses, parsing config files with secrets, or working with customer data. Vexyn's JSON formatter runs entirely in your browser using <code class="text-[color:var(--color-brand-400)]">JSON.parse</code> and <code class="text-[color:var(--color-brand-400)]">JSON.stringify</code>. Your JSON never leaves your device, never touches a server, and nothing gets logged.
      </p>

      <h2 class="text-2xl font-bold mb-4 mt-10">What it does</h2>
      <ul class="space-y-2 text-[color:var(--color-text-mute)] mb-6">
        <li><strong class="text-[color:var(--color-text)]">Format (beautify):</strong> indent your JSON with 2 spaces, 4 spaces, or tabs.</li>
        <li><strong class="text-[color:var(--color-text)]">Minify:</strong> strip all whitespace for smaller payloads.</li>
        <li><strong class="text-[color:var(--color-text)]">Validate:</strong> get precise error messages with line and character positions when JSON is malformed.</li>
        <li><strong class="text-[color:var(--color-text)]">One-click copy:</strong> grab the formatted output to clipboard.</li>
      </ul>

      <h2 class="text-2xl font-bold mb-4 mt-10">Why client-side matters</h2>
      <p class="text-[color:var(--color-text-mute)] leading-relaxed mb-6">
        When you paste JSON into a typical online formatter, it travels across the internet, hits a server, gets processed (and often logged), and travels back. For sensitive data — API keys, tokens, customer records, internal IDs — that's a leak waiting to happen. Vexyn loads a small piece of JavaScript into your browser and lets your own CPU do the work. There is no server-side processing to leak from.
      </p>

      <h2 class="text-2xl font-bold mb-4 mt-10">FAQ</h2>
      <div class="space-y-4">
        <div>
          <h3 class="font-semibold mb-1">Is this really private?</h3>
          <p class="text-[color:var(--color-text-mute)]">Yes. The entire formatter is a few lines of JavaScript running in your browser. We can't see what you paste because it never leaves your device. The code is open source on GitHub.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">What's the size limit?</h3>
          <p class="text-[color:var(--color-text-mute)]">Limited only by your browser's memory — usually hundreds of MBs of JSON without issues. Far more than typical use cases.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">Does it support JSON5 or JSONC?</h3>
          <p class="text-[color:var(--color-text-mute)]">Currently strict JSON only. JSON5 / JSONC (with comments and trailing commas) support is on the roadmap.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">Will my JSON stay if I close the tab?</h3>
          <p class="text-[color:var(--color-text-mute)]">No. Nothing is stored. When you close the tab, everything is gone — that's the privacy guarantee.</p>
        </div>
      </div>
    </article>
  </div>
</BaseLayout>
