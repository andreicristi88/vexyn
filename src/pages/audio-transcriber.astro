---
import BaseLayout from '../layouts/BaseLayout.astro';
import WhisperTranscriber from '../components/tools/WhisperTranscriber.svelte';
import RelatedReading from '../components/ui/RelatedReading.astro';
import { SITE } from '../lib/constants';
import { breadcrumbSchema, faqSchema, webAppSchema, combineSchemas } from '../lib/seo';

const title = 'AI Audio Transcriber';
const description = 'Free speech-to-text that runs entirely on your device using OpenAI Whisper. Drop an audio file, get a transcript in seconds. 99+ languages, no upload, no API, no signup.';

const faqs = [
  { q: 'How is this free if it uses OpenAI Whisper?', a: 'Whisper is open source (MIT licensed). The model is downloaded once into your browser and runs on your own CPU or GPU via WebGPU. There is no API call to pay for — operating cost stays zero regardless of how many people use it.' },
  { q: 'Is my audio really not uploaded?', a: 'No. Inference happens inside your browser tab. Open DevTools → Network and verify — zero requests fire while transcribing (the model file is fetched once at startup, then cached forever).' },
  { q: 'How accurate is it compared to paid transcription services?', a: 'Whisper Base (~145 MB) is competitive with paid services for clear speech in English and major languages. Heavy accents, overlapping speakers, or very poor audio still benefit from larger commercial models — but for typical voice memos, meetings, and podcasts, it works very well.' },
  { q: 'Why is the transcript for my song / music nonsense?', a: 'Whisper is trained on spoken voice, not music. Songs with lyrics often get mangled or hallucinated — even OpenAI\'s largest Whisper model struggles with music. Use this tool for speech content (podcasts, interviews, meetings, voice memos). For lyric transcription, dedicated music-trained models are needed.' },
  { q: 'Why does auto-detect get the language wrong?', a: 'Language detection looks at the first few seconds of audio. On short clips, music intros, or noisy starts it can guess poorly — then the model transcribes the rest in the wrong language and the output is garbage. If you know the language, pick it manually from the dropdown for much better results.' },
  { q: 'How long does the first load take?', a: 'About 5–30 seconds depending on your connection (~75 MB for Tiny, ~145 MB for Base). After that, the model is cached and subsequent visits start instantly.' },
  { q: 'Why is it slow on my phone or laptop?', a: 'Mobile and older devices fall back to WASM (CPU-only), which is roughly 3–5× slower than WebGPU. Switch to the Tiny model in the top-right toggle for faster results, at the cost of slight accuracy.' },
  { q: 'Which languages does it support?', a: 'Whisper supports 99+ languages out of the box. The model auto-detects the language by default, or you can pick one manually from the dropdown. Translation to English is also supported via the Mode switch.' },
  { q: 'What audio formats work?', a: 'MP3, WAV, M4A, OGG, FLAC, AAC, OPUS, WEBM — anything your browser can decode. The tool internally resamples to 16 kHz mono (Whisper\'s expected input).' },
  { q: 'Can I get subtitles for a video?', a: 'Yes — extract the audio from your video (any video editor or ffmpeg), drop it here, then download the result as SRT or VTT. Both formats are subtitle-ready.' },
];

const schema = combineSchemas(
  webAppSchema({
    name: `${title} — ${SITE.name}`,
    url: `${SITE.url}/audio-transcriber`,
    description,
    category: 'MultimediaApplication',
    features: [
      'Free speech-to-text using OpenAI Whisper',
      'Runs entirely on your device via WebGPU',
      'Supports 99+ languages',
      'Translation to English mode',
      'Download as TXT, SRT, or VTT subtitles',
      'No upload, no signup, no API',
      'Works offline once loaded',
    ],
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Audio Transcriber', url: '/audio-transcriber' },
  ]),
  faqSchema(faqs),
);
---

<BaseLayout title={title} description={description} image="/og/audio-transcriber.png" schema={schema}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-8">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">Audio Transcriber</span>
      </div>
      <h1 class="text-4xl font-bold tracking-tight mb-3">AI Audio Transcriber</h1>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-2xl">
        Drop an audio file. Get a transcript. OpenAI Whisper runs entirely in your browser via WebGPU — your voice never leaves your device.
      </p>
    </header>

    <WhisperTranscriber client:load />

    <article class="prose mt-16 max-w-3xl">
      <h2 class="text-2xl font-bold mb-4">Transcription that doesn't see your audio</h2>
      <p class="text-[color:var(--color-text-mute)] leading-relaxed mb-6">
        Most popular transcription services work by uploading your audio to their servers, transcribing there, and sending the result back. Most also charge per minute or per month. For voice memos with personal thoughts, internal meeting recordings, medical or legal interviews, that's a privacy trade-off most people accept without thinking.
      </p>
      <p class="text-[color:var(--color-text-mute)] leading-relaxed mb-6">
        Vexyn uses the same model many of those services use behind the scenes — <a class="text-[color:var(--color-brand-400)] hover:underline" href="https://github.com/openai/whisper" target="_blank" rel="noopener noreferrer">OpenAI Whisper</a>, which is open source under MIT — but runs it directly in your browser via <a class="text-[color:var(--color-brand-400)] hover:underline" href="https://github.com/huggingface/transformers.js" target="_blank" rel="noopener noreferrer">transformers.js</a> with WebGPU acceleration. Your audio is decoded locally, fed to the model locally, and the transcript appears on the same machine. Network tab will confirm: zero outgoing requests during transcription.
      </p>

      <h2 class="text-2xl font-bold mb-4 mt-10">How fast is it?</h2>
      <ul class="space-y-2 text-[color:var(--color-text-mute)] mb-6">
        <li><strong class="text-[color:var(--color-text)]">Desktop + WebGPU + Whisper Tiny:</strong> roughly 10× real-time (10 min audio → ~1 min)</li>
        <li><strong class="text-[color:var(--color-text)]">Desktop + WebGPU + Whisper Base:</strong> roughly 4–6× real-time, noticeably better accuracy</li>
        <li><strong class="text-[color:var(--color-text)]">Desktop + WASM fallback:</strong> roughly 1–2× real-time (still usable)</li>
        <li><strong class="text-[color:var(--color-text)]">Mobile / weak laptop + WASM:</strong> 0.3–0.8× real-time — use the Tiny model</li>
      </ul>

      <h2 class="text-2xl font-bold mb-4 mt-10">Tiny vs Base — which to pick?</h2>
      <p class="text-[color:var(--color-text-mute)] leading-relaxed mb-6">
        <strong class="text-[color:var(--color-text)]">Tiny</strong> (~75 MB) is the fastest, lowest-quality option. Good for quick rough drafts, voice memos, single-speaker English, and mobile devices. <strong class="text-[color:var(--color-text)]">Base</strong> (~145 MB) is the sweet spot — competitive with paid services on most content, still small enough to feel fast on a modern laptop with WebGPU. Switch models in the top-right toggle; switching reloads the model (cached after first download).
      </p>

      <h2 class="text-2xl font-bold mb-4 mt-10">Use cases</h2>
      <ul class="space-y-2 text-[color:var(--color-text-mute)] mb-6">
        <li><strong class="text-[color:var(--color-text)]">Voice memos:</strong> turn your phone recordings into searchable text without sending them to a third party</li>
        <li><strong class="text-[color:var(--color-text)]">Meeting recordings:</strong> internal meetings transcribed without contractual / compliance worries</li>
        <li><strong class="text-[color:var(--color-text)]">Podcast / video subtitles:</strong> export as SRT or VTT and drop directly into a video editor</li>
        <li><strong class="text-[color:var(--color-text)]">Interviews:</strong> journalist / research interviews, off the record</li>
        <li><strong class="text-[color:var(--color-text)]">Language learning:</strong> use translate mode to turn foreign-language audio into English text</li>
      </ul>

      <RelatedReading articles={[
        { href: '/blog/how-to-transcribe-audio-for-free-without-uploading', title: 'How to transcribe audio for free without uploading', description: 'Step-by-step guide: three concrete methods, language detection pitfalls, exporting as SRT or VTT.' },
        { href: '/blog/webgpu-explained-ai-in-the-browser', title: 'WebGPU explained — running AI in the browser', description: 'How Whisper runs locally, why it matters for privacy and cost, and the honest limits in 2026.' },
      ]} />

      <h2 class="text-2xl font-bold mb-4 mt-10">FAQ</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
            <h3 class="font-semibold mb-2">{f.q}</h3>
            <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed">{f.a}</p>
          </div>
        ))}
      </div>
    </article>
  </div>
</BaseLayout>
