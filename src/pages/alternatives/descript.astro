---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumbSchema, faqSchema, combineSchemas } from '../../lib/seo';

const title = 'Descript Alternative for Transcription (Browser-Only)';
const description = 'Vexyn is a Descript alternative for audio transcription that runs entirely on your device. No upload, no signup, no monthly minute cap. Whisper Base in 99+ languages.';

const faqs = [
  { q: 'Does Vexyn do audio/video editing like Descript?', a: 'No. Vexyn is transcription only. Descript is a full audio and video editor where the transcript is the timeline — that is its core innovation. If editing podcasts or videos by editing the text is what you need, Descript is the right tool. If you just need the transcript itself, Vexyn covers that without uploading.' },
  { q: 'What about Studio Sound, Overdub, and voice cloning?', a: 'Those are Descript-specific paid features (noise removal, AI voice generation) that have no equivalent in Vexyn. They run on Descript servers and require uploaded audio. Vexyn focuses narrowly on local-first transcription.' },
  { q: 'Is the transcription accuracy comparable?', a: "Descript uses larger proprietary models behind their cloud, typically 95-98% on clear speech. Whisper Base (Vexyn) is 90-95% on the same audio. For most podcasting and interview transcripts the difference is small. Where it shows up: technical jargon, brand names, heavy accents — both make mistakes there, but Descript's larger model edges ahead." },
  { q: 'Can I export an SRT for video editing?', a: 'Yes — Vexyn exports TXT, SRT, and VTT directly. Drop the SRT into any video editor (Premiere, Final Cut, DaVinci, CapCut) and you have captions.' },
];

const schema = combineSchemas(
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Alternatives', url: '/alternatives' },
    { name: 'Descript', url: '/alternatives/descript' },
  ]),
  faqSchema(faqs),
);
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-10">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <a href="/alternatives" class="hover:text-[color:var(--color-text)]">Alternatives</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">Descript</span>
      </div>

      <p class="text-xs font-medium text-[color:var(--color-text-dim)] uppercase tracking-wider mb-2">Alternative to Descript</p>
      <h1 class="text-4xl font-bold tracking-tight mb-4">A Descript alternative for transcription that runs locally</h1>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-3xl leading-relaxed">
        Descript is a powerful audio/video editor — the transcript-as-timeline is genuinely innovative. But every project you open uploads audio to their cloud. If you only need the transcript (not the editing), Vexyn does the same job in your browser with OpenAI Whisper.
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/audio-transcriber" class="px-5 py-2.5 rounded-lg bg-[color:var(--color-brand-500)] hover:bg-[color:var(--color-brand-600)] text-white font-medium transition-colors inline-flex items-center gap-2">
          Open Audio Transcriber
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/blog/how-to-transcribe-audio-for-free-without-uploading" class="px-5 py-2.5 rounded-lg border border-[color:var(--color-border)] hover:border-[color:var(--color-border-strong)] bg-[color:var(--color-surface)] text-[color:var(--color-text)] font-medium transition-colors">
          Read the guide
        </a>
      </div>
    </header>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-5">Side-by-side</h2>
      <div class="overflow-x-auto rounded-xl border border-[color:var(--color-border)]">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-[color:var(--color-surface)] border-b border-[color:var(--color-border)]">
              <th class="text-left p-4 font-medium text-[color:var(--color-text-mute)]"></th>
              <th class="text-left p-4 font-semibold text-[color:var(--color-brand-400)]">Vexyn</th>
              <th class="text-left p-4 font-semibold">Descript</th>
            </tr>
          </thead>
          <tbody class="text-[color:var(--color-text-mute)]">
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Where audio is processed</td>
              <td class="p-4">In your browser</td>
              <td class="p-4">Descript cloud (uploads from desktop app)</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Audio uploaded?</td>
              <td class="p-4 text-[color:var(--color-success)]">No</td>
              <td class="p-4">Yes</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Account required</td>
              <td class="p-4 text-[color:var(--color-success)]">No</td>
              <td class="p-4">Yes</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Free tier limit</td>
              <td class="p-4 text-[color:var(--color-success)]">Unlimited</td>
              <td class="p-4">1 hour transcription/month free</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Audio/video editing</td>
              <td class="p-4">No (transcription only)</td>
              <td class="p-4 text-[color:var(--color-success)]">Full editor (transcript-as-timeline)</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Studio Sound (noise removal)</td>
              <td class="p-4">No</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes (cloud-based)</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Overdub / AI voice clone</td>
              <td class="p-4">No</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes (paid tiers)</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Languages</td>
              <td class="p-4 text-[color:var(--color-success)]">99+ (Whisper)</td>
              <td class="p-4">~23</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Speaker labels</td>
              <td class="p-4">Manual</td>
              <td class="p-4 text-[color:var(--color-success)]">Automatic</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Export formats</td>
              <td class="p-4">TXT, SRT, VTT</td>
              <td class="p-4">TXT, DOCX, SRT, VTT, video</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Works offline</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes (after first load)</td>
              <td class="p-4">Limited</td>
            </tr>
            <tr>
              <td class="p-4 text-[color:var(--color-text)] font-medium">Price</td>
              <td class="p-4 text-[color:var(--color-success)]">Free, unlimited</td>
              <td class="p-4">Free tier + $12–$30/mo</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-[color:var(--color-text-dim)] mt-3">
        Based on publicly available information from <a href="https://descript.com" target="_blank" rel="noopener noreferrer" class="hover:text-[color:var(--color-text-mute)] underline">descript.com</a> as of June 2026. Verify before relying on a specific number.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">When to pick which</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
          <h3 class="font-semibold text-[color:var(--color-brand-400)] mb-2">Pick Vexyn when…</h3>
          <ul class="text-sm text-[color:var(--color-text-mute)] space-y-1.5 list-disc list-inside">
            <li>You just need the transcript — no editing</li>
            <li>Audio is sensitive (private interviews, internal recordings)</li>
            <li>You transcribe more than 1 hour a month and don't want to pay</li>
            <li>You need a language Descript doesn't fully support</li>
            <li>You work offline</li>
          </ul>
        </div>
        <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
          <h3 class="font-semibold mb-2">Pick Descript when…</h3>
          <ul class="text-sm text-[color:var(--color-text-mute)] space-y-1.5 list-disc list-inside">
            <li>You edit podcasts or videos by editing the transcript</li>
            <li>You want Studio Sound noise removal</li>
            <li>Voice cloning (Overdub) is part of your workflow</li>
            <li>You collaborate with a team on episodes</li>
            <li>You need automatic speaker diarization</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">FAQ</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
            <h3 class="font-semibold mb-2">{f.q}</h3>
            <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="p-6 rounded-xl bg-gradient-to-br from-[color:var(--color-brand-500)]/10 to-[color:var(--color-accent-500)]/10 border border-[color:var(--color-brand-500)]/30">
      <h2 class="text-xl font-bold mb-2">Try the transcriber</h2>
      <p class="text-sm text-[color:var(--color-text-mute)] mb-4">Drop an audio file. Confirm nothing is uploaded by opening DevTools → Network.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/audio-transcriber" class="px-5 py-2.5 rounded-lg bg-[color:var(--color-brand-500)] hover:bg-[color:var(--color-brand-600)] text-white font-medium transition-colors">Open Audio Transcriber</a>
        <a href="/blog/how-to-transcribe-audio-for-free-without-uploading" class="px-5 py-2.5 rounded-lg border border-[color:var(--color-border)] hover:border-[color:var(--color-border-strong)] bg-[color:var(--color-surface)] text-[color:var(--color-text)] font-medium transition-colors">Read the guide →</a>
      </div>
    </section>
  </div>
</BaseLayout>
