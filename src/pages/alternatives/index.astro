---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../lib/constants';
import { breadcrumbSchema, combineSchemas } from '../../lib/seo';

const title = 'Alternatives to Popular Online Tools';
const description = 'Privacy-first alternatives to TinyPNG, ILovePDF, Remove.bg, SmallPDF and other popular online tools. No uploads, no signup, runs in your browser.';

const alternatives = [
  {
    competitor: 'TinyPNG',
    slug: 'tinypng',
    vexynTools: ['Image Compressor', 'Image Format Converter'],
    angle: 'Same compression quality without sending images to their servers.',
  },
  {
    competitor: 'ILovePDF',
    slug: 'ilovepdf',
    vexynTools: ['PDF Merger', 'PDF Splitter'],
    angle: 'Merge and split PDFs in your browser. No uploads, no quotas.',
  },
  {
    competitor: 'Remove.bg',
    slug: 'removebg',
    vexynTools: ['AI Background Remover'],
    angle: 'AI background removal that runs on your device via WebGPU. No API.',
  },
  {
    competitor: 'SmallPDF',
    slug: 'smallpdf',
    vexynTools: ['PDF Merger', 'PDF Splitter'],
    angle: 'PDF tools without the daily-limit paywall or account requirement.',
  },
];

const schema = combineSchemas(
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Alternatives', url: '/alternatives' },
  ]),
);
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-10">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">Alternatives</span>
      </div>
      <h1 class="text-4xl font-bold tracking-tight mb-4">Privacy-first alternatives to popular online tools</h1>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-3xl leading-relaxed">
        Most popular online tools — TinyPNG, ILovePDF, Remove.bg, SmallPDF — work by uploading your files to their servers. That's fine for public content, but for contracts, IDs, internal screenshots, customer data, or anything sensitive, you probably don't want it transiting through someone else's infrastructure. Vexyn does the same jobs entirely in your browser.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
      {alternatives.map(alt => (
        <a
          href={`/alternatives/${alt.slug}`}
          class="group p-6 rounded-xl bg-[color:var(--color-surface)] border border-[color:var(--color-border)] hover:border-[color:var(--color-brand-500)] hover:-translate-y-0.5 hover:shadow-2xl hover:shadow-[color:var(--color-brand-500)]/10 transition-all block"
        >
          <p class="text-xs font-medium text-[color:var(--color-text-dim)] uppercase tracking-wider mb-1">Alternative to</p>
          <h2 class="text-2xl font-bold mb-2 group-hover:text-[color:var(--color-brand-400)] transition-colors">{alt.competitor}</h2>
          <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed mb-3">{alt.angle}</p>
          <div class="flex flex-wrap gap-1.5">
            {alt.vexynTools.map(t => (
              <span class="text-xs px-2 py-0.5 rounded bg-[color:var(--color-surface-2)] border border-[color:var(--color-border)] text-[color:var(--color-text-mute)]">{t}</span>
            ))}
          </div>
        </a>
      ))}
    </div>

    <article class="prose max-w-3xl">
      <h2 class="text-2xl font-bold mb-4">Why a "privacy alternative" actually means something here</h2>
      <p class="text-[color:var(--color-text-mute)] leading-relaxed mb-6">
        Saying "we don't store your data" is one thing. Not <em>being able</em> to store it because you never had it is a different thing. Vexyn's tools are JavaScript and WebAssembly that load into your browser and process files on your own CPU or GPU. Open DevTools → Network when you use them — zero requests fire. The same property that makes uploading-based tools convenient (a beefy server) makes them a privacy liability. Pushing the work onto the device removes the liability and the operating cost at the same time.
      </p>

      <h2 class="text-2xl font-bold mb-4 mt-10">What you trade off</h2>
      <p class="text-[color:var(--color-text-mute)] leading-relaxed mb-6">
        Honesty: browser-local tools have real limits. Very large files (hundreds of MB) hit browser memory ceilings. AI models add a one-time download (~85 MB for the background remover, cached forever afterwards). Cold-start performance on weak mobile devices is slower than a beefy server. For everyday work — under a few hundred MB at a time, on a modern machine — none of this matters. For batch industrial workloads, a paid server-side tool is still the right pick.
      </p>

      <h2 class="text-2xl font-bold mb-4 mt-10">All Vexyn tools</h2>
      <p class="text-[color:var(--color-text-mute)] leading-relaxed mb-4">
        Browse the full list on the <a class="text-[color:var(--color-brand-400)] hover:underline" href="/">homepage</a> — every tool runs the same way (in your browser, no upload).
      </p>
    </article>
  </div>
</BaseLayout>
