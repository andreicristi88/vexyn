---
import BaseLayout from '../layouts/BaseLayout.astro';
import HubGrid from '../components/ui/HubGrid.astro';
import { HUBS, toolsForHub } from '../lib/categories';
import { SITE } from '../lib/constants';
import { breadcrumbSchema, combineSchemas, itemListSchema } from '../lib/seo';

const hub = HUBS.pdf;
const tools = toolsForHub('pdf');

const schema = combineSchemas(
  {
    '@type': 'CollectionPage',
    name: hub.seoTitle,
    url: `${SITE.url}/${hub.slug}`,
    description: hub.seoDescription,
  },
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: hub.label, url: `/${hub.slug}` },
  ]),
  itemListSchema(
    tools.map((t) => ({ name: t.name, url: `/${t.slug}`, description: t.description })),
  ),
);
---

<BaseLayout title={hub.seoTitle} description={hub.seoDescription} schema={schema}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-10">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">{hub.label}</span>
      </div>

      <div class="flex items-center gap-3 mb-4">
        <span class="text-3xl" aria-hidden="true">{hub.icon}</span>
        <h1 class="text-4xl font-bold tracking-tight">{hub.tagline}</h1>
      </div>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-3xl leading-relaxed">
        {hub.intro}
      </p>
      <p class="mt-4 text-sm text-[color:var(--color-text-mute)]">
        <span class="font-semibold text-[color:var(--color-text)]">{tools.length}</span> tools, all client-side, no upload.
      </p>
    </header>

    <HubGrid hub="pdf" />

    <section class="prose mt-16 max-w-3xl">
      <h2 class="text-2xl font-bold mb-4">Why local-first PDF tools matter</h2>
      <p class="text-[color:var(--color-text-mute)] leading-relaxed mb-6">
        PDFs hold a lot of life — signed contracts, bank statements, medical records, tax returns, ID scans. The common pattern of uploading them to a server to do a 30-second operation (merge, split, compress) means the file passes through someone else's infrastructure, gets processed by code you can't audit, and lives briefly in their logs. Vexyn does the same operations with libraries like <a href="https://github.com/Hopding/pdf-lib" class="text-[color:var(--color-brand-400)] hover:underline" target="_blank" rel="noopener noreferrer">pdf-lib</a> and <a href="https://github.com/mozilla/pdf.js" class="text-[color:var(--color-brand-400)] hover:underline" target="_blank" rel="noopener noreferrer">PDF.js</a> running inside your browser. Open DevTools → Network and confirm: zero requests fire while you use any of these tools.
      </p>

      <h2 class="text-2xl font-bold mb-4 mt-10">What we cover vs ILovePDF / SmallPDF</h2>
      <p class="text-[color:var(--color-text-mute)] leading-relaxed mb-3">
        We ship the 13 most-googled operations that can be done well in a browser. We explicitly don't ship server-only features — PDF to Word, PDF to Excel, AI summarization, text editing with reflow — because doing them locally either requires shipping a 200 MB AI model or produces low-quality output. When you need those, LibreOffice or Adobe Acrobat handle them locally without uploading.
      </p>

      <h2 class="text-2xl font-bold mb-4 mt-10">Related guides on the blog</h2>
      <ul class="text-[color:var(--color-text-mute)] space-y-2">
        <li><a href="/blog/how-to-merge-pdfs-without-uploading" class="text-[color:var(--color-brand-400)] hover:underline">How to merge PDFs without uploading them</a></li>
        <li><a href="/blog/how-to-split-a-pdf-into-separate-pages" class="text-[color:var(--color-brand-400)] hover:underline">How to split a PDF into separate pages</a></li>
        <li><a href="/blog/best-privacy-first-pdf-tools-2026" class="text-[color:var(--color-brand-400)] hover:underline">Best privacy-first PDF tools in 2026</a></li>
      </ul>
    </section>
  </div>
</BaseLayout>
