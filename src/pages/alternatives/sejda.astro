---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumbSchema, faqSchema, combineSchemas } from '../../lib/seo';

const title = 'Sejda Alternative Without Daily Limits';
const description = 'Vexyn is a Sejda alternative for merging and splitting PDFs that runs entirely in your browser. No upload, no 200 MB / 50 page / 3 tasks per hour daily cap, no account.';

const faqs = [
  { q: "Why does Sejda limit free users to 3 tasks per hour?", a: "Server-side PDF processing has real cost — they need to rate-limit free traffic to keep paid customers responsive. That's a sensible business decision but a frustrating UX when you have 5 quick splits to do. Vexyn doesn't have server cost, so there is no inherent reason to cap usage." },
  { q: 'Does Vexyn have all of Sejda\'s features?', a: 'Vexyn ships 13 PDF tools today: Merger, Splitter, Compressor, Rotator, JPG↔PDF, Unlocker, Protector, Watermark, OCR, Organizer, Page Numbers, Cropper. Sejda adds server-only features (edit text, fill forms, real redaction, PDF to Word). Those don\'t work well client-side. For those tasks, LibreOffice Draw and Adobe Acrobat Pro handle them locally.' },
  { q: 'Are uploaded files on Sejda safe?', a: 'Sejda claims 2-hour automatic deletion. That\'s a policy, not a guarantee — during the window your file lives on their servers and goes through their processing pipeline. For documents you would not share publicly, that\'s a privacy decision worth being explicit about. Vexyn does not have files to delete because they never leave your browser.' },
  { q: 'What about the Sejda desktop app?', a: 'Sejda Desktop processes locally on Windows/Mac/Linux. If you want the full Sejda feature set offline, the Desktop app is the right pick. For the subset Vexyn covers (merge, split), it works without install on any platform.' },
];

const schema = combineSchemas(
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Alternatives', url: '/alternatives' },
    { name: 'Sejda', url: '/alternatives/sejda' },
  ]),
  faqSchema(faqs),
);
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-10">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <a href="/alternatives" class="hover:text-[color:var(--color-text)]">Alternatives</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">Sejda</span>
      </div>

      <p class="text-xs font-medium text-[color:var(--color-text-dim)] uppercase tracking-wider mb-2">Alternative to Sejda</p>
      <h1 class="text-4xl font-bold tracking-tight mb-4">A Sejda alternative without the per-hour task cap</h1>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-3xl leading-relaxed">
        Sejda online caps free users at 200 MB / 50 pages / 3 tasks per hour — the kind of soft paywall that gets noticeable when you have a stack of files to process. Vexyn merges and splits PDFs in your browser with zero caps because there are no server costs to amortize.
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/pdf-merger" class="px-5 py-2.5 rounded-lg bg-[color:var(--color-brand-500)] hover:bg-[color:var(--color-brand-600)] text-white font-medium transition-colors inline-flex items-center gap-2">
          Open PDF Merger
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/pdf-splitter" class="px-5 py-2.5 rounded-lg border border-[color:var(--color-border)] hover:border-[color:var(--color-border-strong)] bg-[color:var(--color-surface)] text-[color:var(--color-text)] font-medium transition-colors">
          Or split PDFs
        </a>
      </div>
    </header>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-5">Side-by-side</h2>
      <div class="overflow-x-auto rounded-xl border border-[color:var(--color-border)]">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-[color:var(--color-surface)] border-b border-[color:var(--color-border)]">
              <th class="text-left p-4 font-medium text-[color:var(--color-text-mute)]"></th>
              <th class="text-left p-4 font-semibold text-[color:var(--color-brand-400)]">Vexyn</th>
              <th class="text-left p-4 font-semibold">Sejda (Online)</th>
            </tr>
          </thead>
          <tbody class="text-[color:var(--color-text-mute)]">
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Where files are processed</td>
              <td class="p-4">In your browser</td>
              <td class="p-4">Sejda cloud</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Files uploaded?</td>
              <td class="p-4 text-[color:var(--color-success)]">No</td>
              <td class="p-4">Yes (2h retention claimed)</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Account required</td>
              <td class="p-4 text-[color:var(--color-success)]">No</td>
              <td class="p-4">No (anon free tier)</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Free tier limits</td>
              <td class="p-4 text-[color:var(--color-success)]">Unlimited</td>
              <td class="p-4">200 MB / 50 pages / 3 tasks per hour</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">PDF Merger</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes</td>
              <td class="p-4">Yes</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">PDF Splitter</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes</td>
              <td class="p-4">Yes</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Compress / Rotate / Watermark</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">OCR / Organize / Page numbers / Crop</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Protect / Unlock (password)</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes (AES-128)</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">JPG↔PDF</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes (both directions)</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Edit text / fill forms / e-sign</td>
              <td class="p-4">No (server-only — see LibreOffice / Adobe Reader)</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Desktop app available</td>
              <td class="p-4">No (browser only)</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes (Win/Mac/Linux)</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Works offline</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes (after first load)</td>
              <td class="p-4">Web: no; Desktop: yes</td>
            </tr>
            <tr>
              <td class="p-4 text-[color:var(--color-text)] font-medium">Price</td>
              <td class="p-4 text-[color:var(--color-success)]">Free, unlimited</td>
              <td class="p-4">Free tier + $7.50–$15/mo</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-[color:var(--color-text-dim)] mt-3">
        Based on publicly available information from <a href="https://sejda.com" target="_blank" rel="noopener noreferrer" class="hover:text-[color:var(--color-text-mute)] underline">sejda.com</a> as of June 2026. Verify before relying on a specific number.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">When to pick which</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
          <h3 class="font-semibold text-[color:var(--color-brand-400)] mb-2">Pick Vexyn when…</h3>
          <ul class="text-sm text-[color:var(--color-text-mute)] space-y-1.5 list-disc list-inside">
            <li>You need any of the 13 core operations, without per-hour caps</li>
            <li>PDFs contain sensitive data</li>
            <li>You can't install a desktop app on the machine you're using</li>
            <li>You're on mobile or a Chromebook</li>
            <li>You want a no-account, no-paywall path</li>
          </ul>
        </div>
        <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
          <h3 class="font-semibold mb-2">Pick Sejda when…</h3>
          <ul class="text-sm text-[color:var(--color-text-mute)] space-y-1.5 list-disc list-inside">
            <li>You need to edit PDF text directly</li>
            <li>You need OCR, form-fill, or e-sign</li>
            <li>You want a full desktop PDF suite (Sejda Desktop)</li>
            <li>The 3-tasks-per-hour cap is fine for your workflow</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">FAQ</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
            <h3 class="font-semibold mb-2">{f.q}</h3>
            <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="p-6 rounded-xl bg-gradient-to-br from-[color:var(--color-brand-500)]/10 to-[color:var(--color-accent-500)]/10 border border-[color:var(--color-brand-500)]/30">
      <h2 class="text-xl font-bold mb-2">Try the PDF tools</h2>
      <p class="text-sm text-[color:var(--color-text-mute)] mb-4">Drop PDFs. Merge or split. No 3-per-hour cap, no upload.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/pdf-merger" class="px-5 py-2.5 rounded-lg bg-[color:var(--color-brand-500)] hover:bg-[color:var(--color-brand-600)] text-white font-medium transition-colors">Open PDF Merger</a>
        <a href="/pdf-splitter" class="px-5 py-2.5 rounded-lg border border-[color:var(--color-border)] hover:border-[color:var(--color-border-strong)] bg-[color:var(--color-surface)] text-[color:var(--color-text)] font-medium transition-colors">Or split PDFs →</a>
      </div>
    </section>
  </div>
</BaseLayout>
