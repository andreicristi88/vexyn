---
import { SITE, NAV } from '../../lib/constants';
import ThemeToggle from '../ui/ThemeToggle.svelte';
import Logo from '../ui/Logo.astro';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  if (href.startsWith('http') || href.startsWith('#') || href.includes('#')) return false;
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href + '/');
};
const isAnyChildActive = (children?: Array<{ href: string }>) =>
  !!children?.some((c) => isActive(c.href));
---

<header class="sticky top-0 z-50 backdrop-blur-xl bg-[color:var(--color-bg)]/80 border-b border-[color:var(--color-border)]">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between" aria-label="Main">
    <a href="/" class="flex items-center gap-2 group" aria-label={`${SITE.name} home`}>
      <Logo size={32} class="group-hover:scale-110 transition-transform" />
      <span class="font-semibold text-lg tracking-tight">{SITE.name}</span>
    </a>

    <div class="flex items-center gap-0.5 sm:gap-1">
      {NAV.map((item) => {
        const active = isActive(item.href) || isAnyChildActive(item.children);

        if (item.children) {
          return (
            <details class="vexyn-dropdown relative">
              <summary
                class:list={[
                  'px-2 sm:px-3 py-2 text-sm font-medium transition-colors rounded-md cursor-pointer flex items-center gap-1 list-none',
                  active
                    ? 'text-[color:var(--color-text)] bg-[color:var(--color-surface)]'
                    : 'text-[color:var(--color-text-mute)] hover:text-[color:var(--color-text)] hover:bg-[color:var(--color-surface)]'
                ]}
                aria-haspopup="menu"
              >
                {item.label}
                <svg class="vexyn-chev w-3 h-3 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </summary>
              <div class="vexyn-menu absolute right-0 sm:right-auto sm:left-0 top-full mt-1 w-72 rounded-xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] shadow-2xl shadow-black/30 overflow-hidden">
                {item.children.map((c) => {
                  const childActive = isActive(c.href);
                  return (
                    <a
                      href={c.href}
                      aria-current={childActive ? 'page' : undefined}
                      class:list={[
                        'block px-4 py-3 text-sm transition-colors',
                        childActive
                          ? 'bg-[color:var(--color-surface-2)] text-[color:var(--color-text)]'
                          : 'hover:bg-[color:var(--color-surface-2)] text-[color:var(--color-text)]'
                      ]}
                    >
                      <div class="font-medium">{c.label}</div>
                      {c.description && (
                        <div class="text-xs text-[color:var(--color-text-mute)] mt-0.5">{c.description}</div>
                      )}
                    </a>
                  );
                })}
              </div>
            </details>
          );
        }

        if (item.external) {
          return (
            <a
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={item.label}
              class:list={[
                'w-9 h-9 sm:w-auto sm:h-auto sm:px-3 sm:py-2 flex items-center justify-center text-sm font-medium transition-colors rounded-md',
                'text-[color:var(--color-text-mute)] hover:text-[color:var(--color-text)] hover:bg-[color:var(--color-surface)]'
              ]}
            >
              <svg class="w-4 h-4 sm:hidden" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
              </svg>
              <span class="hidden sm:inline">{item.label}</span>
            </a>
          );
        }
        return (
          <a
            href={item.href}
            aria-current={active ? 'page' : undefined}
            class:list={[
              'px-2 sm:px-3 py-2 text-sm font-medium transition-colors rounded-md',
              active
                ? 'text-[color:var(--color-text)] bg-[color:var(--color-surface)]'
                : 'text-[color:var(--color-text-mute)] hover:text-[color:var(--color-text)] hover:bg-[color:var(--color-surface)]'
            ]}
          >
            {item.label}
          </a>
        );
      })}
      <ThemeToggle client:load />
    </div>
  </nav>
</header>

<style is:global>
  /* Hide default details marker — we draw our own chevron */
  details.vexyn-dropdown > summary::-webkit-details-marker { display: none; }
  details.vexyn-dropdown > summary { list-style: none; }
  details.vexyn-dropdown[open] .vexyn-chev { transform: rotate(180deg); }
</style>

<script>
  // Close other open dropdowns when one opens; close on outside click + Escape.
  document.addEventListener('click', (e) => {
    const target = e.target as Element;
    document.querySelectorAll<HTMLDetailsElement>('details.vexyn-dropdown[open]').forEach((d) => {
      if (!d.contains(target)) d.removeAttribute('open');
    });
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelectorAll<HTMLDetailsElement>('details.vexyn-dropdown[open]').forEach((d) => d.removeAttribute('open'));
    }
  });
  // Single-open dropdowns
  document.querySelectorAll<HTMLDetailsElement>('details.vexyn-dropdown').forEach((d) => {
    d.addEventListener('toggle', () => {
      if (d.open) {
        document.querySelectorAll<HTMLDetailsElement>('details.vexyn-dropdown[open]').forEach((other) => {
          if (other !== d) other.removeAttribute('open');
        });
      }
    });
  });
</script>
