---
import BaseLayout from '../layouts/BaseLayout.astro';
import PdfSplitter from '../components/tools/PdfSplitter.svelte';
import { SITE } from '../lib/constants';
import RelatedReading from '../components/ui/RelatedReading.astro';
import { breadcrumbSchema, faqSchema, webAppSchema, combineSchemas } from '../lib/seo';

const title = 'PDF Splitter';
const description = 'Split a PDF into single-page files or extract a custom range. Runs in your browser — your document never gets uploaded.';

const faqs = [
  { q: "What's the size limit?", a: 'Browser memory is the limit. ~500 MB usually works on desktops.' },
  { q: 'Will my data go anywhere?', a: 'No. The splitter is JavaScript running locally. Verify with DevTools — no requests fire when you split.' },
  { q: 'Why are encrypted PDFs rejected?', a: "Encrypted PDFs can't be re-saved without their key. Open in a viewer, save a copy without password, then try again." },
];

const schema = combineSchemas(
  webAppSchema({ name: `${title} — ${SITE.name}`, url: `${SITE.url}/pdf-splitter`, description }),
  breadcrumbSchema([{ name: 'Home', url: '/' }, { name: title, url: '/pdf-splitter' }]),
  faqSchema(faqs),
);
---

<BaseLayout title={title} description={description} image="/og/pdf-splitter.png" schema={schema}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-8">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">PDF Splitter</span>
      </div>
      <h1 class="text-4xl font-bold tracking-tight mb-3">PDF Splitter</h1>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-2xl">
        Split a PDF into single-page files (ZIP) or extract just the pages you want. Everything runs in your browser — no upload, no signup.
      </p>
    </header>

    <PdfSplitter client:load />

    <article class="prose mt-16 max-w-3xl">
      <h2 class="text-2xl font-bold mb-4">A PDF splitter that respects your privacy</h2>
      <p class="text-[color:var(--color-text-mute)] leading-relaxed mb-6">
        Popular online PDF splitters upload your file, process it on a server, and stream the output back. Fine for public documents, terrible for contracts, statements, or anything with sensitive content. Vexyn does the split in your browser with <a class="text-[color:var(--color-brand-400)] hover:underline" href="https://github.com/Hopding/pdf-lib" target="_blank" rel="noopener noreferrer">pdf-lib</a>. The file picker hands bytes to JavaScript, the split happens against your CPU, and the output is offered as a download. DevTools → Network shows zero traffic when you split.
      </p>

      <h2 class="text-2xl font-bold mb-4 mt-10">Two modes</h2>
      <ul class="space-y-2 text-[color:var(--color-text-mute)] mb-6">
        <li><strong class="text-[color:var(--color-text)]">Split each page (ZIP):</strong> get N separate <code class="text-[color:var(--color-brand-400)]">page-001.pdf</code>, <code class="text-[color:var(--color-brand-400)]">page-002.pdf</code> files bundled in a ZIP.</li>
        <li><strong class="text-[color:var(--color-text)]">Extract range:</strong> specify pages and ranges like <code class="text-[color:var(--color-brand-400)]">1-3, 5, 7-9</code> to get a single merged PDF with just those pages.</li>
      </ul>

      <RelatedReading articles={[
        { href: '/blog/how-to-split-a-pdf-into-separate-pages', title: 'How to split a PDF into separate pages', description: 'Step-by-step guide: range syntax, encrypted PDFs, common silent-failure modes, and verification.' },
        { href: '/blog/best-privacy-first-pdf-tools-2026', title: 'Best privacy-first PDF tools in 2026', description: 'Five picks for merging, splitting, and cleaning PDFs locally without uploading.' },
      ]} />

      <h2 class="text-2xl font-bold mb-4 mt-10">FAQ</h2>
      <div class="space-y-4">
        <div>
          <h3 class="font-semibold mb-1">What's the size limit?</h3>
          <p class="text-[color:var(--color-text-mute)]">Browser memory is the limit. ~500 MB usually works on desktops.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">Will my data go anywhere?</h3>
          <p class="text-[color:var(--color-text-mute)]">No. The splitter is JavaScript running locally. Verify with DevTools — no requests fire when you split.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">Why are encrypted PDFs rejected?</h3>
          <p class="text-[color:var(--color-text-mute)]">Encrypted PDFs can't be re-saved without their key. Open in a viewer, save a copy without password, then try again.</p>
        </div>
      </div>
    </article>
  </div>
</BaseLayout>
