---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ui/ToolCard.astro';
import { TOOLS } from '../lib/tools';
import { SITE } from '../lib/constants';

const availableTools = TOOLS.filter(t => t.available);
const comingTools = TOOLS.filter(t => !t.available);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE.url}/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout schema={schema}>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 glow pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16 sm:pt-28 sm:pb-24 relative">
      <div class="flex flex-col items-center text-center max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface)] text-xs text-[color:var(--color-text-mute)] mb-6">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-[color:var(--color-success)]"></span>
          100% client-side. Nothing uploaded. Ever.
        </div>

        <h1 class="text-5xl sm:text-6xl md:text-7xl font-bold tracking-tight mb-6 leading-[1.05]">
          Tools that <span class="gradient-text">stay on your device</span>.
        </h1>

        <p class="text-lg sm:text-xl text-[color:var(--color-text-mute)] mb-10 leading-relaxed max-w-2xl">
          Free browser tools that never upload your files. No signup. No tracking. No ads. Everything runs locally, instantly.
        </p>

        <div class="flex flex-col sm:flex-row items-center gap-3">
          <a href="#tools" class="px-6 py-3 rounded-lg bg-[color:var(--color-brand-500)] hover:bg-[color:var(--color-brand-600)] text-white font-medium transition-colors flex items-center gap-2">
            Browse tools
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href={SITE.github} target="_blank" rel="noopener noreferrer" class="px-6 py-3 rounded-lg border border-[color:var(--color-border)] hover:border-[color:var(--color-border-strong)] bg-[color:var(--color-surface)] hover:bg-[color:var(--color-surface-2)] text-[color:var(--color-text)] font-medium transition-colors flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
            Star on GitHub
          </a>
        </div>

        <div class="mt-16 grid grid-cols-3 gap-8 sm:gap-16 text-center">
          <div>
            <div class="text-2xl sm:text-3xl font-bold gradient-text">100%</div>
            <div class="text-xs text-[color:var(--color-text-mute)] mt-1">Local</div>
          </div>
          <div>
            <div class="text-2xl sm:text-3xl font-bold gradient-text">0</div>
            <div class="text-xs text-[color:var(--color-text-mute)] mt-1">Uploads</div>
          </div>
          <div>
            <div class="text-2xl sm:text-3xl font-bold gradient-text">∞</div>
            <div class="text-xs text-[color:var(--color-text-mute)] mt-1">Free uses</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tools -->
  <section id="tools" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-end justify-between mb-8">
      <div>
        <h2 class="text-3xl font-bold tracking-tight mb-2">Tools</h2>
        <p class="text-[color:var(--color-text-mute)]">Pick a tool. Drop your file. Done — no servers involved.</p>
      </div>
      <div class="hidden sm:flex text-xs text-[color:var(--color-text-dim)] gap-3">
        <span>{availableTools.length} live</span>
        <span>•</span>
        <span>{comingTools.length} coming</span>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {availableTools.map(tool => <ToolCard tool={tool} />)}
      {comingTools.map(tool => <ToolCard tool={tool} />)}
    </div>
  </section>

  <!-- Why -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="p-6 rounded-xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)]">
        <div class="w-10 h-10 rounded-lg bg-[color:var(--color-success)]/10 border border-[color:var(--color-success)]/30 flex items-center justify-center mb-4">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h3 class="font-semibold mb-2">Your files never leave</h3>
        <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed">Every tool processes data directly in your browser. We don't have servers that touch your files — because they don't exist.</p>
      </div>
      <div class="p-6 rounded-xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)]">
        <div class="w-10 h-10 rounded-lg bg-[color:var(--color-brand-500)]/10 border border-[color:var(--color-brand-500)]/30 flex items-center justify-center mb-4">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-400)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 2 13 9 22 9"/><polyline points="22 14 13 14 13 21"/><polyline points="2 9 11 9 11 2"/><polyline points="11 22 11 14 2 14"/></svg>
        </div>
        <h3 class="font-semibold mb-2">No signup, no ads, no tracking</h3>
        <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed">No accounts. No cookies. No analytics scripts watching you. Just tools that work and disappear when you close the tab.</p>
      </div>
      <div class="p-6 rounded-xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)]">
        <div class="w-10 h-10 rounded-lg bg-[color:var(--color-accent-500)]/10 border border-[color:var(--color-accent-500)]/30 flex items-center justify-center mb-4">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent-400)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <h3 class="font-semibold mb-2">Instant. Offline-capable.</h3>
        <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed">No round-trips to a server. Tools run as fast as your device allows. Once loaded, many work without internet.</p>
      </div>
    </div>
  </section>
</BaseLayout>
