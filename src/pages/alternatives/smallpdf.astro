---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../lib/constants';
import { breadcrumbSchema, faqSchema, combineSchemas } from '../../lib/seo';

const title = 'SmallPDF Alternative Without the Daily Limit';
const description = 'Vexyn is a SmallPDF alternative for merging and splitting PDFs that runs in your browser. No daily quota, no signup, no upload — your documents never leave your device.';

const faqs = [
  { q: 'Will Vexyn hit me with a 2-document-per-day cap like SmallPDF?', a: 'No. There is no quota. The tool runs on your device, so there is nothing to meter.' },
  { q: 'Does Vexyn support the same PDF formats SmallPDF does?', a: 'For merging and splitting — yes, any standard PDF. Encrypted/password-protected PDFs need their password removed first (we flag them clearly instead of failing silently).' },
  { q: 'Why is there no upload?', a: 'Vexyn uses pdf-lib, a JavaScript PDF library that runs in your browser. The file picker hands PDF bytes directly to JS, which assembles the merged/split output and offers it as a download. No server in the loop.' },
  { q: 'Does Vexyn have a Pro tier?', a: 'No. The whole point of running on the user\'s device is that there is no scaling cost — so there is no paid tier to push.' },
];

const schema = combineSchemas(
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Alternatives', url: '/alternatives' },
    { name: 'SmallPDF', url: '/alternatives/smallpdf' },
  ]),
  faqSchema(faqs),
);
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-10">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <a href="/alternatives" class="hover:text-[color:var(--color-text)]">Alternatives</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">SmallPDF</span>
      </div>
      <p class="text-xs font-medium text-[color:var(--color-text-dim)] uppercase tracking-wider mb-2">Alternative to SmallPDF</p>
      <h1 class="text-4xl font-bold tracking-tight mb-4">A SmallPDF alternative without the daily limit or paywall</h1>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-3xl leading-relaxed">
        SmallPDF works well but caps free use at 2 documents per day and pushes you toward a paid plan. Vexyn merges and splits PDFs in your browser with no daily limit, no signup, no upload.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/pdf-merger" class="px-5 py-2.5 rounded-lg bg-[color:var(--color-brand-500)] hover:bg-[color:var(--color-brand-600)] text-white font-medium transition-colors inline-flex items-center gap-2">
          Open PDF Merger
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/pdf-splitter" class="px-5 py-2.5 rounded-lg border border-[color:var(--color-border)] hover:border-[color:var(--color-border-strong)] bg-[color:var(--color-surface)] text-[color:var(--color-text)] font-medium transition-colors">Or split a PDF</a>
      </div>
    </header>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-5">Side-by-side</h2>
      <div class="overflow-x-auto rounded-xl border border-[color:var(--color-border)]">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-[color:var(--color-surface)] border-b border-[color:var(--color-border)]">
              <th class="text-left p-4 font-medium text-[color:var(--color-text-mute)]"></th>
              <th class="text-left p-4 font-semibold text-[color:var(--color-brand-400)]">Vexyn</th>
              <th class="text-left p-4 font-semibold">SmallPDF</th>
            </tr>
          </thead>
          <tbody class="text-[color:var(--color-text-mute)]">
            <tr class="border-b border-[color:var(--color-border)]"><td class="p-4 text-[color:var(--color-text)] font-medium">Where files are processed</td><td class="p-4">In your browser</td><td class="p-4">SmallPDF servers (Switzerland)</td></tr>
            <tr class="border-b border-[color:var(--color-border)]"><td class="p-4 text-[color:var(--color-text)] font-medium">Files uploaded?</td><td class="p-4 text-[color:var(--color-success)]">No</td><td class="p-4">Yes</td></tr>
            <tr class="border-b border-[color:var(--color-border)]"><td class="p-4 text-[color:var(--color-text)] font-medium">Daily free limit</td><td class="p-4 text-[color:var(--color-success)]">Unlimited</td><td class="p-4">2 documents / day (free)</td></tr>
            <tr class="border-b border-[color:var(--color-border)]"><td class="p-4 text-[color:var(--color-text)] font-medium">Account required?</td><td class="p-4 text-[color:var(--color-success)]">No</td><td class="p-4">For Pro features</td></tr>
            <tr class="border-b border-[color:var(--color-border)]"><td class="p-4 text-[color:var(--color-text)] font-medium">File size limit</td><td class="p-4">~500 MB (browser memory)</td><td class="p-4">Capped on free tier</td></tr>
            <tr class="border-b border-[color:var(--color-border)]"><td class="p-4 text-[color:var(--color-text)] font-medium">PDF tools available</td><td class="p-4">Merger + Splitter today</td><td class="p-4">20+ tools incl. compress, convert, sign</td></tr>
            <tr class="border-b border-[color:var(--color-border)]"><td class="p-4 text-[color:var(--color-text)] font-medium">Works offline</td><td class="p-4 text-[color:var(--color-success)]">Yes (after first load)</td><td class="p-4">No</td></tr>
            <tr class="border-b border-[color:var(--color-border)]"><td class="p-4 text-[color:var(--color-text)] font-medium">Open source</td><td class="p-4 text-[color:var(--color-success)]">Yes (MIT)</td><td class="p-4">No</td></tr>
            <tr><td class="p-4 text-[color:var(--color-text)] font-medium">Price</td><td class="p-4 text-[color:var(--color-success)]">Free forever</td><td class="p-4">Free w/ cap + Pro ($9/mo)</td></tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-[color:var(--color-text-dim)] mt-3">
        Based on publicly available information from <a href="https://smallpdf.com" target="_blank" rel="noopener noreferrer" class="hover:text-[color:var(--color-text-mute)] underline">smallpdf.com</a> as of June 2026.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">When to pick which</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
          <h3 class="font-semibold text-[color:var(--color-brand-400)] mb-2">Pick Vexyn when…</h3>
          <ul class="text-sm text-[color:var(--color-text-mute)] space-y-1.5 list-disc list-inside">
            <li>You hit the 2-document daily cap regularly</li>
            <li>PDFs contain sensitive content you'd rather not upload</li>
            <li>You only need merge or split (no compress / OCR / sign yet)</li>
            <li>You don't want an account</li>
            <li>You want the work to be doable offline</li>
          </ul>
        </div>
        <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
          <h3 class="font-semibold mb-2">Pick SmallPDF when…</h3>
          <ul class="text-sm text-[color:var(--color-text-mute)] space-y-1.5 list-disc list-inside">
            <li>You need OCR, e-signing, page numbering, or conversion to/from Office formats</li>
            <li>You're already paying for Pro and use the full feature set</li>
            <li>Your PDFs are non-sensitive</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">FAQ</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
            <h3 class="font-semibold mb-2">{f.q}</h3>
            <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="p-6 rounded-xl bg-gradient-to-br from-[color:var(--color-brand-500)]/10 to-[color:var(--color-accent-500)]/10 border border-[color:var(--color-brand-500)]/30">
      <h2 class="text-xl font-bold mb-2">Try the PDF tools</h2>
      <p class="text-sm text-[color:var(--color-text-mute)] mb-4">No quota counter. No upload. Drop a few PDFs and merge or split as many times as you want.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/pdf-merger" class="px-5 py-2.5 rounded-lg bg-[color:var(--color-brand-500)] hover:bg-[color:var(--color-brand-600)] text-white font-medium transition-colors">Open PDF Merger</a>
        <a href="/pdf-splitter" class="px-5 py-2.5 rounded-lg border border-[color:var(--color-border)] hover:border-[color:var(--color-border-strong)] bg-[color:var(--color-surface)] text-[color:var(--color-text)] font-medium transition-colors">Or split a PDF →</a>
      </div>
    </section>
  </div>
</BaseLayout>
