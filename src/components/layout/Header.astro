---
import { SITE, NAV } from '../../lib/constants';
import ThemeToggle from '../ui/ThemeToggle.svelte';
---

<header class="sticky top-0 z-50 backdrop-blur-xl bg-[color:var(--color-bg)]/80 border-b border-[color:var(--color-border)]">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-[color:var(--color-brand-500)] to-[color:var(--color-accent-500)] flex items-center justify-center text-white font-bold text-lg group-hover:scale-110 transition-transform">
        V
      </div>
      <span class="font-semibold text-lg tracking-tight">{SITE.name}</span>
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      {NAV.map((item) => (
        <a
          href={item.href}
          target={item.external ? '_blank' : undefined}
          rel={item.external ? 'noopener noreferrer' : undefined}
          class="px-3 py-2 text-sm font-medium text-[color:var(--color-text-mute)] hover:text-[color:var(--color-text)] transition-colors rounded-md hover:bg-[color:var(--color-surface)]"
        >
          {item.label}
        </a>
      ))}
      <ThemeToggle client:load />
    </div>
  </nav>
</header>
