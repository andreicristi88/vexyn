---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../lib/constants';
import { breadcrumbSchema, faqSchema, combineSchemas } from '../../lib/seo';

const title = 'ILovePDF Alternative That Keeps Your Documents Local';
const description = 'Vexyn is an ILovePDF alternative for merging and splitting PDFs that runs entirely in your browser. No upload, no signup, no daily quota — your documents never leave your device.';

const faqs = [
  { q: 'Why would I use Vexyn over ILovePDF?', a: 'If your PDFs contain anything sensitive — contracts, statements, signed documents, medical records — Vexyn keeps them on your device. ILovePDF needs to upload them to process.' },
  { q: 'Does Vexyn have all the tools ILovePDF has?', a: 'Vexyn ships 13 PDF tools today: Merger, Splitter, Compressor, Rotator, JPG↔PDF, Unlocker, Protector, Watermark, OCR, Organizer, Page Numbers, Cropper. ILovePDF has roughly twice that, mostly server-only features like PDF to Word, PDF to Excel, edit text, and certificate-based signing. Those don\'t work well client-side without a 200 MB AI model in your browser. For those tasks, desktop tools like LibreOffice or Adobe Acrobat handle them locally too.' },
  { q: 'Is there a file size limit?', a: 'Browser memory is the only limit — roughly 500 MB total on a typical desktop. ILovePDF has hard caps (25 MB free, 100 MB paid).' },
  { q: 'How does Vexyn make money if everything is free?', a: 'It doesn\'t, currently. The site costs ~$15/year (the domain) and runs on free Cloudflare Pages. Because every tool runs on your device, there\'s no per-request server cost forcing a paywall on the existing tools. Future support (sponsorships, non-tracking referrals) would never break the architectural promises — no upload, no signup, no tracking.' },
];

const schema = combineSchemas(
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Alternatives', url: '/alternatives' },
    { name: 'ILovePDF', url: '/alternatives/ilovepdf' },
  ]),
  faqSchema(faqs),
);
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-10">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <a href="/alternatives" class="hover:text-[color:var(--color-text)]">Alternatives</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">ILovePDF</span>
      </div>
      <p class="text-xs font-medium text-[color:var(--color-text-dim)] uppercase tracking-wider mb-2">Alternative to ILovePDF</p>
      <h1 class="text-4xl font-bold tracking-tight mb-4">An ILovePDF alternative that keeps PDFs on your device</h1>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-3xl leading-relaxed">
        ILovePDF works by uploading your PDFs to their servers. For public documents that's fine. For contracts, statements, IDs, and anything sensitive, Vexyn does the merge and split locally — no upload, no quota, no signup.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/pdf-merger" class="px-5 py-2.5 rounded-lg bg-[color:var(--color-brand-500)] hover:bg-[color:var(--color-brand-600)] text-white font-medium transition-colors inline-flex items-center gap-2">
          Open PDF Merger
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/pdf-splitter" class="px-5 py-2.5 rounded-lg border border-[color:var(--color-border)] hover:border-[color:var(--color-border-strong)] bg-[color:var(--color-surface)] text-[color:var(--color-text)] font-medium transition-colors">Or split a PDF</a>
      </div>
    </header>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-5">Side-by-side</h2>
      <div class="overflow-x-auto rounded-xl border border-[color:var(--color-border)]">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-[color:var(--color-surface)] border-b border-[color:var(--color-border)]">
              <th class="text-left p-4 font-medium text-[color:var(--color-text-mute)]"></th>
              <th class="text-left p-4 font-semibold text-[color:var(--color-brand-400)]">Vexyn</th>
              <th class="text-left p-4 font-semibold">ILovePDF</th>
            </tr>
          </thead>
          <tbody class="text-[color:var(--color-text-mute)]">
            <tr class="border-b border-[color:var(--color-border)]"><td class="p-4 text-[color:var(--color-text)] font-medium">Where files are processed</td><td class="p-4">In your browser</td><td class="p-4">ILovePDF servers (Barcelona)</td></tr>
            <tr class="border-b border-[color:var(--color-border)]"><td class="p-4 text-[color:var(--color-text)] font-medium">Files uploaded?</td><td class="p-4 text-[color:var(--color-success)]">No</td><td class="p-4">Yes</td></tr>
            <tr class="border-b border-[color:var(--color-border)]"><td class="p-4 text-[color:var(--color-text)] font-medium">Account required?</td><td class="p-4 text-[color:var(--color-success)]">No</td><td class="p-4">Free tier without, premium requires it</td></tr>
            <tr class="border-b border-[color:var(--color-border)]"><td class="p-4 text-[color:var(--color-text)] font-medium">File size limit</td><td class="p-4">~500 MB (browser memory)</td><td class="p-4">25 MB free, up to 100 MB premium</td></tr>
            <tr class="border-b border-[color:var(--color-border)]"><td class="p-4 text-[color:var(--color-text)] font-medium">Daily usage limit</td><td class="p-4 text-[color:var(--color-success)]">Unlimited</td><td class="p-4">Limited free, more on paid</td></tr>
            <tr class="border-b border-[color:var(--color-border)]"><td class="p-4 text-[color:var(--color-text)] font-medium">Number of PDF tools</td><td class="p-4">13 today</td><td class="p-4">~28 (incl. server-only)</td></tr>
            <tr class="border-b border-[color:var(--color-border)]"><td class="p-4 text-[color:var(--color-text)] font-medium">Merge / Split / Compress / Rotate</td><td class="p-4 text-[color:var(--color-success)]">Yes</td><td class="p-4">Yes</td></tr>
            <tr class="border-b border-[color:var(--color-border)]"><td class="p-4 text-[color:var(--color-text)] font-medium">OCR / Watermark / Protect / Unlock</td><td class="p-4 text-[color:var(--color-success)]">Yes</td><td class="p-4">Yes</td></tr>
            <tr class="border-b border-[color:var(--color-border)]"><td class="p-4 text-[color:var(--color-text)] font-medium">PDF to Word / Excel / PowerPoint</td><td class="p-4">No (server-only)</td><td class="p-4">Yes</td></tr>
            <tr class="border-b border-[color:var(--color-border)]"><td class="p-4 text-[color:var(--color-text)] font-medium">Edit PDF text / certificate signing</td><td class="p-4">No (use LibreOffice / Adobe Reader)</td><td class="p-4">Yes</td></tr>
            <tr class="border-b border-[color:var(--color-border)]"><td class="p-4 text-[color:var(--color-text)] font-medium">Works offline</td><td class="p-4 text-[color:var(--color-success)]">Yes (after first load)</td><td class="p-4">No (requires upload)</td></tr>
            <tr class="border-b border-[color:var(--color-border)]"><td class="p-4 text-[color:var(--color-text)] font-medium">Open source</td><td class="p-4 text-[color:var(--color-success)]">Yes (MIT)</td><td class="p-4">No</td></tr>
            <tr><td class="p-4 text-[color:var(--color-text)] font-medium">Price</td><td class="p-4 text-[color:var(--color-success)]">Free, unlimited</td><td class="p-4">Free + Premium ($4–$9/mo)</td></tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-[color:var(--color-text-dim)] mt-3">
        Based on publicly available information from <a href="https://www.ilovepdf.com" target="_blank" rel="noopener noreferrer" class="hover:text-[color:var(--color-text-mute)] underline">ilovepdf.com</a> as of June 2026.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">When to pick which</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
          <h3 class="font-semibold text-[color:var(--color-brand-400)] mb-2">Pick Vexyn when…</h3>
          <ul class="text-sm text-[color:var(--color-text-mute)] space-y-1.5 list-disc list-inside">
            <li>The PDFs contain anything personal or contractual</li>
            <li>You hit ILovePDF's free quota or 25 MB cap regularly</li>
            <li>You want the tool to work offline</li>
            <li>You need any of the 13 core operations: merge, split, compress, rotate, JPG↔PDF, unlock, protect, watermark, OCR, organize, page numbers, crop</li>
            <li>You'd rather not create an account</li>
          </ul>
        </div>
        <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
          <h3 class="font-semibold mb-2">Pick ILovePDF when…</h3>
          <ul class="text-sm text-[color:var(--color-text-mute)] space-y-1.5 list-disc list-inside">
            <li>You need PDF to Word / Excel / PowerPoint conversion</li>
            <li>You need to edit PDF body text directly</li>
            <li>You need certificate-based digital signing</li>
            <li>You're doing volume work and need an established paid SLA</li>
            <li>Your PDFs aren't sensitive and you prefer their UI</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">FAQ</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
            <h3 class="font-semibold mb-2">{f.q}</h3>
            <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="p-6 rounded-xl bg-gradient-to-br from-[color:var(--color-brand-500)]/10 to-[color:var(--color-accent-500)]/10 border border-[color:var(--color-brand-500)]/30">
      <h2 class="text-xl font-bold mb-2">Try the PDF tools</h2>
      <p class="text-sm text-[color:var(--color-text-mute)] mb-4">Drop a couple of PDFs. Confirm nothing is uploaded by opening DevTools → Network.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/pdf-merger" class="px-5 py-2.5 rounded-lg bg-[color:var(--color-brand-500)] hover:bg-[color:var(--color-brand-600)] text-white font-medium transition-colors">Open PDF Merger</a>
        <a href="/pdf-splitter" class="px-5 py-2.5 rounded-lg border border-[color:var(--color-border)] hover:border-[color:var(--color-border-strong)] bg-[color:var(--color-surface)] text-[color:var(--color-text)] font-medium transition-colors">Or split a PDF →</a>
      </div>
    </section>
  </div>
</BaseLayout>
