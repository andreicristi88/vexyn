---
import BaseLayout from '../layouts/BaseLayout.astro';
import QrGenerator from '../components/tools/QrGenerator.svelte';
import { SITE } from '../lib/constants';
import { breadcrumbSchema, faqSchema, webAppSchema, combineSchemas } from '../lib/seo';

const title = 'QR Code Generator';
const description = 'Free customizable QR code generator. Choose colors, size, and error correction. Download as PNG or SVG. Everything runs in your browser.';

const faqs = [
  { q: 'Are the QR codes tracked?', a: 'No. The QR code encodes the exact text you enter, with no redirect or shortener in the middle. Scanners go directly to your destination.' },
  { q: 'When should I use PNG vs SVG?', a: 'SVG for printing or any case where sharpness matters at varied sizes. PNG for social media, slides, or anywhere you need a raster image.' },
  { q: "My QR code isn't scanning — what's wrong?", a: 'Common causes: contrast too low (use dark on light), margin too small (use at least 2), or too much data (try Q/H error correction or shorten the text).' },
  { q: 'Can I use these QR codes commercially?', a: 'Yes. The codes generated here are public domain — use them anywhere.' },
];

const schema = combineSchemas(
  webAppSchema({
    name: `${title} — ${SITE.name}`,
    url: `${SITE.url}/qr-generator`,
    description,
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'QR Generator', url: '/qr-generator' },
  ]),
  faqSchema(faqs),
);
---

<BaseLayout title={title} description={description} image="/og/qr-generator.png" schema={schema}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-8">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">QR Generator</span>
      </div>
      <h1 class="text-4xl font-bold tracking-tight mb-3">QR Code Generator</h1>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-2xl">
        Create customizable QR codes for URLs, text, Wi-Fi, contact cards, and more. Download as PNG or SVG. No tracking pixels — just QR codes.
      </p>
    </header>

    <QrGenerator client:load />

    <article class="prose mt-16 max-w-3xl">
      <h2 class="text-2xl font-bold mb-4">A QR generator without tracking</h2>
      <p class="text-[color:var(--color-text-mute)] leading-relaxed mb-6">
        Many popular QR generators wrap your destination URL in their own redirect — bit.ly-style — so they can count scans and sell analytics. That breaks if their service goes down, and it leaks every scanner's IP and user agent to a third party. Vexyn's generator never does that. The QR code you download encodes exactly the text you typed. The only thing scanners see is your link.
      </p>

      <h2 class="text-2xl font-bold mb-4 mt-10">Customization options</h2>
      <ul class="space-y-2 text-[color:var(--color-text-mute)] mb-6">
        <li><strong class="text-[color:var(--color-text)]">Size:</strong> 128px to 1024px, perfect for posters, business cards, or sticker prints.</li>
        <li><strong class="text-[color:var(--color-text)]">Margin:</strong> control the quiet zone around the code (some scanners need more).</li>
        <li><strong class="text-[color:var(--color-text)]">Error correction:</strong> L (7%), M (15%), Q (25%), H (30%) — higher levels survive damage and printing artifacts better.</li>
        <li><strong class="text-[color:var(--color-text)]">Colors:</strong> any foreground/background combo (keep enough contrast for scanners).</li>
        <li><strong class="text-[color:var(--color-text)]">Format:</strong> PNG for raster use, SVG for sharp print at any size.</li>
      </ul>

      <h2 class="text-2xl font-bold mb-4 mt-10">What can you encode?</h2>
      <p class="text-[color:var(--color-text-mute)] leading-relaxed mb-6">
        Anything that fits in text: URLs, plain text, phone numbers (<code>tel:+1234567890</code>), email links (<code>mailto:hi@example.com</code>), Wi-Fi credentials (<code>WIFI:S:network;T:WPA;P:password;;</code>), vCards, calendar events. QR codes can hold up to ~3 KB of data, though shorter content scans more reliably.
      </p>

      <h2 class="text-2xl font-bold mb-4 mt-10">FAQ</h2>
      <div class="space-y-4">
        <div>
          <h3 class="font-semibold mb-1">Are the QR codes tracked?</h3>
          <p class="text-[color:var(--color-text-mute)]">No. The QR code encodes the exact text you enter, with no redirect or shortener in the middle. Scanners go directly to your destination.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">When should I use PNG vs SVG?</h3>
          <p class="text-[color:var(--color-text-mute)]">SVG for printing or any case where sharpness matters at varied sizes. PNG for social media, slides, or anywhere you need a raster image.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">My QR code isn't scanning — what's wrong?</h3>
          <p class="text-[color:var(--color-text-mute)]">Common causes: contrast too low (use dark on light), margin too small (use at least 2), or too much data (try Q/H error correction or shorten the text).</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">Can I use these QR codes commercially?</h3>
          <p class="text-[color:var(--color-text-mute)]">Yes. The codes generated here are public domain — use them anywhere.</p>
        </div>
      </div>
    </article>
  </div>
</BaseLayout>
