---
import BaseLayout from '../layouts/BaseLayout.astro';
import PdfRotator from '../components/tools/PdfRotator.svelte';
import PrivacyNote from '../components/ui/PrivacyNote.astro';
import { SITE } from '../lib/constants';
import { breadcrumbSchema, faqSchema, webAppSchema, combineSchemas } from '../lib/seo';

const title = 'PDF Rotator';
const description = 'Free PDF rotator that runs entirely in your browser. Rotate all pages or a specific range 90, 180, or 270 degrees. No upload, no signup.';

const faqs = [
  { q: 'Does it rotate forever after each save?', a: 'No — rotation is cumulative within a single session. Pick the angle and target pages, save once, done. The output PDF has the new orientation baked in.' },
  { q: 'Can I rotate just some pages?', a: 'Yes. Switch to "Specific pages" and enter a range like 1-3, 5, 7-9. Other pages stay as they are.' },
  { q: 'Is the file uploaded?', a: 'No. Rotation is a pdf-lib operation that runs in your browser. Verify in DevTools → Network — no requests fire.' },
  { q: 'What about encrypted PDFs?', a: "They can't be modified without their password. Unlock them first with the PDF Unlocker, then rotate." },
];

const schema = combineSchemas(
  webAppSchema({
    name: `${title} — ${SITE.name}`,
    url: `${SITE.url}/pdf-rotator`,
    description,
    features: ['Rotate 90 / 180 / 270 degrees', 'All pages or specific range', 'Cumulative rotation', '100% local'],
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'PDF Rotator', url: '/pdf-rotator' },
  ]),
  faqSchema(faqs),
);
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-8">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">PDF Rotator</span>
      </div>
      <h1 class="text-4xl font-bold tracking-tight mb-3">PDF Rotator</h1>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-2xl">
        Rotate every page or just the ones you choose. Runs in your browser — your document never gets uploaded.
      </p>
    </header>

    <PrivacyNote />
    <PdfRotator client:load />

    <article class="prose mt-16 max-w-3xl">
      <h2 class="text-2xl font-bold mb-4">Rotation that doesn't see your PDF</h2>
      <p class="text-[color:var(--color-text-mute)] leading-relaxed mb-6">
        Rotating a PDF is one of the most common "fix this scan" tasks. Online PDF rotators upload your file to do a one-line operation that pdf-lib can do locally in milliseconds. Vexyn does the rotation in your browser; the output is byte-faithful to the input except for the page rotation metadata.
      </p>

      <h2 class="text-2xl font-bold mb-4 mt-10">FAQ</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
            <h3 class="font-semibold mb-2">{f.q}</h3>
            <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed">{f.a}</p>
          </div>
        ))}
      </div>
    </article>
  </div>
</BaseLayout>
