---
import type { Tool } from '../../lib/tools';
import { CATEGORIES } from '../../lib/tools';

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
const cat = CATEGORIES[tool.category];
const href = tool.available ? `/${tool.slug}` : '#';
---

<a
  href={href}
  aria-disabled={!tool.available}
  tabindex={tool.available ? 0 : -1}
  class:list={[
    'group relative block p-6 rounded-xl border transition-all',
    tool.available
      ? 'bg-[color:var(--color-surface)] border-[color:var(--color-border)] hover:border-[color:var(--color-brand-500)] hover:-translate-y-0.5 hover:shadow-2xl hover:shadow-[color:var(--color-brand-500)]/10'
      : 'bg-[color:var(--color-surface)]/50 border-[color:var(--color-border)] opacity-60 cursor-not-allowed pointer-events-none'
  ]}
>
  <div class="flex items-start justify-between mb-4">
    <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-[color:var(--color-brand-500)]/20 to-[color:var(--color-accent-500)]/20 border border-[color:var(--color-border)] flex items-center justify-center text-xl font-mono text-[color:var(--color-brand-400)]">
      {tool.icon}
    </div>
    {!tool.available && (
      <span class="text-xs px-2 py-1 rounded-md bg-[color:var(--color-surface-2)] text-[color:var(--color-text-dim)] border border-[color:var(--color-border)]">
        Soon
      </span>
    )}
    <span class:list={[
      'text-xs px-2 py-1 rounded-md uppercase tracking-wider font-medium',
      'bg-[color:var(--color-surface-2)] text-[color:var(--color-text-mute)] border border-[color:var(--color-border)]',
      tool.available ? 'opacity-100' : 'hidden'
    ]}>
      {cat.label}
    </span>
  </div>

  <h3 class="text-lg font-semibold mb-1 text-[color:var(--color-text)] group-hover:text-[color:var(--color-brand-400)] transition-colors">
    {tool.name}
  </h3>
  <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed">
    {tool.description}
  </p>

  {tool.available && (
    <div class="mt-4 flex items-center gap-1 text-sm text-[color:var(--color-brand-400)] opacity-0 group-hover:opacity-100 transition-opacity">
      Open
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"/>
        <polyline points="12 5 19 12 12 19"/>
      </svg>
    </div>
  )}
</a>
