---
import BaseLayout from '../layouts/BaseLayout.astro';
import JpgToPdf from '../components/tools/JpgToPdf.svelte';
import { SITE } from '../lib/constants';
import { breadcrumbSchema, faqSchema, webAppSchema, combineSchemas } from '../lib/seo';

const title = 'JPG to PDF';
const description = 'Combine JPG and PNG images into a single PDF. Reorder pages, pick A4 / Letter / auto-size, adjust margin. Runs entirely in your browser — no upload.';

const faqs = [
  { q: 'What formats are supported?', a: 'JPG (JPEG) and PNG input. The PDF embeds each image as-is — no recompression. Transparency in PNGs is preserved on the page background.' },
  { q: 'Can I reorder before exporting?', a: "Yes — use the up/down arrows on each row. The final PDF follows the order top-to-bottom in the list." },
  { q: 'What does "Auto" page size do?', a: 'Each PDF page matches the image dimensions exactly. Useful for screenshots, comic pages, or anything that should appear at its native ratio. Pick A4 or Letter when the recipient expects standard paper sizes.' },
  { q: 'Is anything uploaded?', a: 'No. Images are embedded in a PDF entirely in your browser using pdf-lib. DevTools → Network shows zero requests.' },
];

const schema = combineSchemas(
  webAppSchema({
    name: `${title} — ${SITE.name}`,
    url: `${SITE.url}/jpg-to-pdf`,
    description,
    features: ['JPG and PNG input', 'Drag-to-reorder', 'A4 / Letter / Auto page size', 'Configurable margins', 'Original quality preserved'],
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'JPG to PDF', url: '/jpg-to-pdf' },
  ]),
  faqSchema(faqs),
);
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-8">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">JPG to PDF</span>
      </div>
      <h1 class="text-4xl font-bold tracking-tight mb-3">JPG to PDF</h1>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-2xl">
        Drop JPG or PNG images, reorder, pick page size, build a PDF. Everything runs in your browser — no upload, no signup.
      </p>
    </header>

    <JpgToPdf client:load />

    <article class="prose mt-16 max-w-3xl">
      <h2 class="text-2xl font-bold mb-4">FAQ</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
            <h3 class="font-semibold mb-2">{f.q}</h3>
            <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed">{f.a}</p>
          </div>
        ))}
      </div>
    </article>
  </div>
</BaseLayout>
