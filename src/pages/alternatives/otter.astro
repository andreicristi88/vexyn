---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumbSchema, faqSchema, combineSchemas } from '../../lib/seo';

const title = 'Otter.ai Alternative That Runs in Your Browser';
const description = 'Vexyn is an Otter.ai alternative that transcribes audio entirely on your device using OpenAI Whisper. No upload, no monthly minute cap, no signup. 99+ languages, SRT and VTT export.';

const faqs = [
  { q: 'Is the transcription quality as good as Otter?', a: 'For clear speech in a quiet recording, Whisper Base (Vexyn) reaches 90-95% word accuracy versus 95-98% for Otter on the same audio. The gap widens for hard audio (multiple overlapping speakers, heavy accents, noisy environments) where Otter uses larger proprietary models. For voice memos, single-speaker interviews, and meetings with clear audio, the difference is negligible.' },
  { q: 'Does Vexyn do speaker diarization (label who said what)?', a: "No. Whisper transcribes the words but doesn't identify speakers. Otter does this well. If you need speaker labels for an interview transcript, you'd add them by hand in Vexyn, or use Otter for that specific job." },
  { q: 'What about live transcription during meetings?', a: 'Vexyn transcribes recorded audio files only — no live mode, no Zoom/Google Meet integration. If you need real-time meeting captions, Otter is the right pick. If you record meetings and transcribe afterwards, Vexyn covers it without sending audio to a third party.' },
  { q: 'Is my audio actually not uploaded?', a: 'Confirmed. Open DevTools → Network when transcribing — zero requests fire. The Whisper model is downloaded once (~75-145 MB depending on size) and cached. After that, transcription is entirely local, even offline.' },
];

const schema = combineSchemas(
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Alternatives', url: '/alternatives' },
    { name: 'Otter.ai', url: '/alternatives/otter' },
  ]),
  faqSchema(faqs),
);
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-10">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <a href="/alternatives" class="hover:text-[color:var(--color-text)]">Alternatives</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">Otter.ai</span>
      </div>

      <p class="text-xs font-medium text-[color:var(--color-text-dim)] uppercase tracking-wider mb-2">Alternative to Otter.ai</p>
      <h1 class="text-4xl font-bold tracking-tight mb-4">An Otter.ai alternative that doesn't upload your audio</h1>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-3xl leading-relaxed">
        Otter.ai is the dominant browser-based transcription service, with real-time meeting captions and speaker labels. But every recording you transcribe travels to Otter's servers and lives in their cloud. Vexyn runs OpenAI Whisper directly on your device — no upload, no minute cap, no account.
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/audio-transcriber" class="px-5 py-2.5 rounded-lg bg-[color:var(--color-brand-500)] hover:bg-[color:var(--color-brand-600)] text-white font-medium transition-colors inline-flex items-center gap-2">
          Open Audio Transcriber
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/blog/how-to-transcribe-audio-for-free-without-uploading" class="px-5 py-2.5 rounded-lg border border-[color:var(--color-border)] hover:border-[color:var(--color-border-strong)] bg-[color:var(--color-surface)] text-[color:var(--color-text)] font-medium transition-colors">
          Read the guide
        </a>
      </div>
    </header>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-5">Side-by-side</h2>
      <div class="overflow-x-auto rounded-xl border border-[color:var(--color-border)]">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-[color:var(--color-surface)] border-b border-[color:var(--color-border)]">
              <th class="text-left p-4 font-medium text-[color:var(--color-text-mute)]"></th>
              <th class="text-left p-4 font-semibold text-[color:var(--color-brand-400)]">Vexyn</th>
              <th class="text-left p-4 font-semibold">Otter.ai</th>
            </tr>
          </thead>
          <tbody class="text-[color:var(--color-text-mute)]">
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Where audio is processed</td>
              <td class="p-4">In your browser (Whisper + WebGPU)</td>
              <td class="p-4">Otter.ai cloud servers</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Audio uploaded?</td>
              <td class="p-4 text-[color:var(--color-success)]">No</td>
              <td class="p-4">Yes</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Account required</td>
              <td class="p-4 text-[color:var(--color-success)]">No</td>
              <td class="p-4">Yes</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Free tier limit</td>
              <td class="p-4 text-[color:var(--color-success)]">Unlimited</td>
              <td class="p-4">300 min/month, 30 min per recording</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Live transcription</td>
              <td class="p-4">No (recorded files only)</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes (Zoom, Meet, Teams)</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Speaker diarization</td>
              <td class="p-4">No (manual labels)</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes (automatic)</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Languages</td>
              <td class="p-4">99+ (Whisper)</td>
              <td class="p-4">English-focused; other languages limited</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Translation to English</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes (Whisper translate mode)</td>
              <td class="p-4">Limited</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Export formats</td>
              <td class="p-4">TXT, SRT, VTT</td>
              <td class="p-4">TXT, PDF, DOCX, SRT</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">AI summary / action items</td>
              <td class="p-4">No</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes (paid tiers)</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Works offline</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes (after first load)</td>
              <td class="p-4">No</td>
            </tr>
            <tr>
              <td class="p-4 text-[color:var(--color-text)] font-medium">Price</td>
              <td class="p-4 text-[color:var(--color-success)]">Free, unlimited</td>
              <td class="p-4">Free tier + $8.33–$20/mo</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-[color:var(--color-text-dim)] mt-3">
        Based on publicly available information from <a href="https://otter.ai" target="_blank" rel="noopener noreferrer" class="hover:text-[color:var(--color-text-mute)] underline">otter.ai</a> as of June 2026. Plan limits and pricing change — verify before relying on a specific number.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">When to pick which</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
          <h3 class="font-semibold text-[color:var(--color-brand-400)] mb-2">Pick Vexyn when…</h3>
          <ul class="text-sm text-[color:var(--color-text-mute)] space-y-1.5 list-disc list-inside">
            <li>Audio contains sensitive content (interviews, voice memos, legal/medical)</li>
            <li>You transcribe more than 5 hours a month and don't want to pay</li>
            <li>You need non-English transcription (Whisper is best-in-class multilingual)</li>
            <li>You'd rather not create yet another SaaS account</li>
            <li>You work offline or on a flaky connection</li>
          </ul>
        </div>
        <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
          <h3 class="font-semibold mb-2">Pick Otter when…</h3>
          <ul class="text-sm text-[color:var(--color-text-mute)] space-y-1.5 list-disc list-inside">
            <li>You need live captions during meetings (Zoom/Meet integration)</li>
            <li>Speaker labels matter (multi-person interviews)</li>
            <li>You want AI-generated summaries and action items</li>
            <li>You collaborate on transcripts with a team</li>
            <li>You need shared workspace storage for past transcripts</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">FAQ</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
            <h3 class="font-semibold mb-2">{f.q}</h3>
            <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="p-6 rounded-xl bg-gradient-to-br from-[color:var(--color-brand-500)]/10 to-[color:var(--color-accent-500)]/10 border border-[color:var(--color-brand-500)]/30">
      <h2 class="text-xl font-bold mb-2">Try the transcriber</h2>
      <p class="text-sm text-[color:var(--color-text-mute)] mb-4">Drop an audio file. Confirm nothing is uploaded by opening DevTools → Network.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/audio-transcriber" class="px-5 py-2.5 rounded-lg bg-[color:var(--color-brand-500)] hover:bg-[color:var(--color-brand-600)] text-white font-medium transition-colors">Open Audio Transcriber</a>
        <a href="/blog/how-to-transcribe-audio-for-free-without-uploading" class="px-5 py-2.5 rounded-lg border border-[color:var(--color-border)] hover:border-[color:var(--color-border-strong)] bg-[color:var(--color-surface)] text-[color:var(--color-text)] font-medium transition-colors">Read the guide →</a>
      </div>
    </section>
  </div>
</BaseLayout>
