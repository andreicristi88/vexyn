---
import { SITE } from '../../lib/constants';
import Logo from '../ui/Logo.astro';
const year = new Date().getFullYear();
---

<footer class="border-t border-[color:var(--color-border)] mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <div class="flex items-center gap-2 mb-3">
          <Logo size={28} />
          <span class="font-semibold">{SITE.name}</span>
        </div>
        <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed">
          {SITE.tagline} Privacy-first browser tools. Everything runs locally on your device.
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold mb-3">Tools</h3>
        <ul class="space-y-2 text-sm text-[color:var(--color-text-mute)]">
          <li><a href="/json-formatter" class="hover:text-[color:var(--color-text)]">JSON Formatter</a></li>
          <li><a href="/base64" class="hover:text-[color:var(--color-text)]">Base64 Encoder</a></li>
          <li><a href="/qr-generator" class="hover:text-[color:var(--color-text)]">QR Generator</a></li>
          <li><a href="/pdf-merger" class="hover:text-[color:var(--color-text)]">PDF Merger</a></li>
          <li><a href="/image-compressor" class="hover:text-[color:var(--color-text)]">Image Compressor</a></li>
          <li><a href="/background-remover" class="hover:text-[color:var(--color-text)]">Background Remover <span class="ml-1 text-[10px] uppercase tracking-wider text-[color:var(--color-accent-400)]">AI</span></a></li>
          <li><a href="/pdf-splitter" class="hover:text-[color:var(--color-text)]">PDF Splitter</a></li>
          <li><a href="/image-converter" class="hover:text-[color:var(--color-text)]">Image Converter</a></li>
          <li><a href="/color-palette" class="hover:text-[color:var(--color-text)]">Color Palette</a></li>
          <li><a href="/exif-remover" class="hover:text-[color:var(--color-text)]">EXIF Remover</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold mb-3">Links</h3>
        <ul class="space-y-2 text-sm text-[color:var(--color-text-mute)]">
          <li><a href="/about" class="hover:text-[color:var(--color-text)]">About</a></li>
          <li><a href="/privacy" class="hover:text-[color:var(--color-text)]">Privacy</a></li>
          <li><a href={SITE.github} target="_blank" rel="noopener noreferrer" class="hover:text-[color:var(--color-text)]">GitHub</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-[color:var(--color-border)] flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-[color:var(--color-text-dim)]">
      <p>© {year} {SITE.name}. Built with privacy in mind.</p>
      <p class="flex items-center gap-2">
        <span class="inline-block w-2 h-2 rounded-full bg-[color:var(--color-success)] animate-pulse"></span>
        <span>No tracking. No cookies. No accounts.</span>
      </p>
    </div>
  </div>
</footer>
