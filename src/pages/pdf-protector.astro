---
import BaseLayout from '../layouts/BaseLayout.astro';
import PdfProtector from '../components/tools/PdfProtector.svelte';
import PrivacyNote from '../components/ui/PrivacyNote.astro';
import { SITE } from '../lib/constants';
import { breadcrumbSchema, faqSchema, webAppSchema, combineSchemas } from '../lib/seo';

const title = 'PDF Protector';
const description = 'Add an AES-128 password to a PDF entirely in your browser. The password is never sent anywhere. Permissions (printing, copying, modifying) are configurable.';

const faqs = [
  { q: 'What encryption is used?', a: 'AES-128 with @cantoo/pdf-lib. The result opens in every modern PDF viewer (Adobe Reader, Preview, Chrome, mobile readers).' },
  { q: 'Is my password really not sent anywhere?', a: 'Yes. Encryption runs entirely in your browser. You can verify by opening DevTools → Network and confirming no requests fire while protecting the PDF.' },
  { q: 'Can the password be recovered if I forget it?', a: "No. That's the whole point of encryption. Pick a password you can remember, or store it in a password manager." },
  { q: 'What permissions are restricted by default?', a: 'Modifying, copying, and document assembly are blocked. Printing (high resolution), annotating, accessibility access, and form-filling are allowed — the common-sense defaults for a "share this but don\'t let it be edited" use case.' },
];

const schema = combineSchemas(
  webAppSchema({
    name: `${title} — ${SITE.name}`,
    url: `${SITE.url}/pdf-protector`,
    description,
    features: ['AES-128 password encryption', 'No-modify, no-copy permissions by default', 'Password typed locally only', '100% local'],
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'PDF Protector', url: '/pdf-protector' },
  ]),
  faqSchema(faqs),
);
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-8">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">PDF Protector</span>
      </div>
      <h1 class="text-4xl font-bold tracking-tight mb-3">PDF Protector</h1>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-2xl">
        Add a password to a PDF in your browser. AES-128 encryption, never uploaded anywhere.
      </p>
    </header>

    <PrivacyNote />
    <PdfProtector client:load />

    <article class="prose mt-16 max-w-3xl">
      <h2 class="text-2xl font-bold mb-4">FAQ</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
            <h3 class="font-semibold mb-2">{f.q}</h3>
            <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed">{f.a}</p>
          </div>
        ))}
      </div>
    </article>
  </div>
</BaseLayout>
