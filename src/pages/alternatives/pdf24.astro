---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumbSchema, faqSchema, combineSchemas } from '../../lib/seo';

const title = 'PDF24 Alternative That Runs in Your Browser';
const description = 'Vexyn is a PDF24 alternative for merging and splitting PDFs that runs entirely in your browser. No upload, no signup, no installer. Drag-and-drop reordering and range extraction included.';

const faqs = [
  { q: 'Does PDF24 not also work offline?', a: 'PDF24 has a desktop installer for Windows that works offline. The PDF24 Online tools (pdf24.org) however upload files to their servers. If you want browser-based PDF work without upload, Vexyn covers the merge and split cases. For a feature-rich desktop suite on Windows, PDF24 is solid.' },
  { q: 'Does Vexyn have all 20+ PDF tools PDF24 has?', a: 'No. Vexyn currently has PDF Merger and PDF Splitter. PDF24 covers OCR, compress, convert-to-image, e-sign, password-protect, and more. We add tools incrementally based on demand — merger and splitter cover the most-common operations.' },
  { q: 'Can I trust that nothing is uploaded?', a: 'Open DevTools → Network in your browser, then drop a PDF in Vexyn and merge or split. Zero requests fire. The tool is plain JavaScript loaded once; everything else happens locally.' },
  { q: 'What about encrypted PDFs?', a: "Encrypted PDFs can't be modified without their password. Vexyn flags them with a clear error rather than failing silently. Decrypt in a viewer first (save an unencrypted copy), then process." },
];

const schema = combineSchemas(
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Alternatives', url: '/alternatives' },
    { name: 'PDF24', url: '/alternatives/pdf24' },
  ]),
  faqSchema(faqs),
);
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-10">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <a href="/alternatives" class="hover:text-[color:var(--color-text)]">Alternatives</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">PDF24</span>
      </div>

      <p class="text-xs font-medium text-[color:var(--color-text-dim)] uppercase tracking-wider mb-2">Alternative to PDF24</p>
      <h1 class="text-4xl font-bold tracking-tight mb-4">A PDF24 alternative without the installer or the upload</h1>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-3xl leading-relaxed">
        PDF24 is a popular German-built PDF toolkit — strong on Windows desktop, less so on web (which uploads files). Vexyn merges and splits PDFs in your browser, no install, no upload, on any platform.
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/pdf-merger" class="px-5 py-2.5 rounded-lg bg-[color:var(--color-brand-500)] hover:bg-[color:var(--color-brand-600)] text-white font-medium transition-colors inline-flex items-center gap-2">
          Open PDF Merger
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/pdf-splitter" class="px-5 py-2.5 rounded-lg border border-[color:var(--color-border)] hover:border-[color:var(--color-border-strong)] bg-[color:var(--color-surface)] text-[color:var(--color-text)] font-medium transition-colors">
          Or split PDFs
        </a>
      </div>
    </header>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-5">Side-by-side</h2>
      <div class="overflow-x-auto rounded-xl border border-[color:var(--color-border)]">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-[color:var(--color-surface)] border-b border-[color:var(--color-border)]">
              <th class="text-left p-4 font-medium text-[color:var(--color-text-mute)]"></th>
              <th class="text-left p-4 font-semibold text-[color:var(--color-brand-400)]">Vexyn</th>
              <th class="text-left p-4 font-semibold">PDF24 (Online)</th>
            </tr>
          </thead>
          <tbody class="text-[color:var(--color-text-mute)]">
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Where files are processed</td>
              <td class="p-4">In your browser</td>
              <td class="p-4">PDF24 servers (Germany)</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Files uploaded?</td>
              <td class="p-4 text-[color:var(--color-success)]">No</td>
              <td class="p-4">Yes</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Installer required?</td>
              <td class="p-4 text-[color:var(--color-success)]">No (any browser)</td>
              <td class="p-4">Online: no; Desktop app: Windows installer</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Cross-platform</td>
              <td class="p-4 text-[color:var(--color-success)]">Windows, Mac, Linux, mobile</td>
              <td class="p-4">Desktop app: Windows only</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Account required</td>
              <td class="p-4 text-[color:var(--color-success)]">No</td>
              <td class="p-4">No</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">PDF Merger</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes</td>
              <td class="p-4">Yes</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">PDF Splitter</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes (range or each page)</td>
              <td class="p-4">Yes</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">OCR (scanned PDFs)</td>
              <td class="p-4">No</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Compress / convert / sign</td>
              <td class="p-4">No (roadmap)</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes (20+ tools)</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Works offline</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes (after first load)</td>
              <td class="p-4">Desktop app: yes; web: no</td>
            </tr>
            <tr>
              <td class="p-4 text-[color:var(--color-text)] font-medium">Price</td>
              <td class="p-4 text-[color:var(--color-success)]">Free, unlimited</td>
              <td class="p-4">Free with ads</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-[color:var(--color-text-dim)] mt-3">
        Based on publicly available information from <a href="https://tools.pdf24.org" target="_blank" rel="noopener noreferrer" class="hover:text-[color:var(--color-text-mute)] underline">tools.pdf24.org</a> as of June 2026. Verify before relying on a specific number.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">When to pick which</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
          <h3 class="font-semibold text-[color:var(--color-brand-400)] mb-2">Pick Vexyn when…</h3>
          <ul class="text-sm text-[color:var(--color-text-mute)] space-y-1.5 list-disc list-inside">
            <li>You only need merge or split, not the full PDF24 suite</li>
            <li>PDFs contain sensitive data (contracts, IDs, statements)</li>
            <li>You're on Mac, Linux, or mobile (no PDF24 desktop)</li>
            <li>You can't install software on the machine you're using</li>
            <li>You want a no-ads experience</li>
          </ul>
        </div>
        <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
          <h3 class="font-semibold mb-2">Pick PDF24 when…</h3>
          <ul class="text-sm text-[color:var(--color-text-mute)] space-y-1.5 list-disc list-inside">
            <li>You're on Windows and want a free desktop suite</li>
            <li>You need OCR for scanned PDFs</li>
            <li>You need compress, convert, sign, password tools (broader feature set)</li>
            <li>You print to PDF from any Windows app via virtual printer</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">FAQ</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
            <h3 class="font-semibold mb-2">{f.q}</h3>
            <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="p-6 rounded-xl bg-gradient-to-br from-[color:var(--color-brand-500)]/10 to-[color:var(--color-accent-500)]/10 border border-[color:var(--color-brand-500)]/30">
      <h2 class="text-xl font-bold mb-2">Try the PDF tools</h2>
      <p class="text-sm text-[color:var(--color-text-mute)] mb-4">Drop PDFs. Merge or split them. Open DevTools → Network — no requests fire.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/pdf-merger" class="px-5 py-2.5 rounded-lg bg-[color:var(--color-brand-500)] hover:bg-[color:var(--color-brand-600)] text-white font-medium transition-colors">Open PDF Merger</a>
        <a href="/pdf-splitter" class="px-5 py-2.5 rounded-lg border border-[color:var(--color-border)] hover:border-[color:var(--color-border-strong)] bg-[color:var(--color-surface)] text-[color:var(--color-text)] font-medium transition-colors">Or split PDFs →</a>
      </div>
    </section>
  </div>
</BaseLayout>
