---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImageUpscaler from '../components/tools/ImageUpscaler.svelte';
import PrivacyNote from '../components/ui/PrivacyNote.astro';
import { SITE } from '../lib/constants';
import { breadcrumbSchema, faqSchema, webAppSchema, combineSchemas } from '../lib/seo';

const title = 'AI Image Upscaler';
const description = 'Free AI image upscaler that runs entirely on your device. 2× or 4× resolution with detail reconstruction via Swin2SR. No upload, no signup, no watermark.';

const faqs = [
  { q: 'How does AI upscaling differ from regular resize?', a: 'A regular resize interpolates between existing pixels — the result is bigger but blurry. An AI upscaler is a neural network trained to invent plausible detail: sharper edges, more texture, less blur. On photos and screenshots the difference is often obvious. On very simple graphics (single-colour blocks) the difference is small.' },
  { q: 'What model does Vexyn use?', a: 'Swin2SR (Xenova/swin2SR-classical-sr-x2-64), a 2× super-resolution model. For 4× output the model runs twice on the intermediate 2× result. The whole thing runs in your browser via WebGPU (or WASM as a fallback on older devices).' },
  { q: "Why is there a size limit on the input?", a: 'Browser GPU memory is finite. Inputs over ~1024×1024 typically exceed available VRAM and either OOM or run extremely slowly. For very large images, upscale in tiles yourself (crop the image, upscale each piece, reassemble).' },
  { q: 'Is my image uploaded?', a: 'No. The model file downloads once (~30 MB, cached afterwards) and everything else runs in your tab. Open DevTools → Network — zero requests fire while upscaling.' },
  { q: 'How does it compare to paid services like Upscayl or Topaz?', a: 'Swin2SR is a solid open-source model. Paid tools use proprietary models tuned for specific cases (faces, illustrations, low-light) that are often noticeably better on hard inputs. For everyday screenshots, product photos, and low-res web images, the difference is smaller than the price gap.' },
];

const schema = combineSchemas(
  webAppSchema({
    name: `${title} — ${SITE.name}`,
    url: `${SITE.url}/image-upscaler`,
    description,
    category: 'MultimediaApplication',
    features: ['2× and 4× AI upscaling', 'Runs entirely in your browser via WebGPU', 'No upload, no signup, no watermark', 'PNG output', 'Works offline once loaded'],
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'AI Image Upscaler', url: '/image-upscaler' },
  ]),
  faqSchema(faqs),
);
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-8">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">AI Image Upscaler</span>
      </div>
      <div class="flex items-center gap-3 mb-3">
        <h1 class="text-4xl font-bold tracking-tight">AI Image Upscaler</h1>
        <span class="text-xs px-2 py-1 rounded-md bg-[color:var(--color-accent-500)]/15 border border-[color:var(--color-accent-500)]/30 text-[color:var(--color-accent-400)] font-medium uppercase tracking-wider">AI · Local</span>
      </div>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-2xl">
        Enlarge photos and screenshots 2× or 4× with AI-invented detail. Swin2SR runs entirely in your browser via WebGPU — your image never leaves your device.
      </p>
    </header>

    <PrivacyNote />
    <ImageUpscaler client:load />

    <article class="prose mt-16 max-w-3xl">
      <h2 class="text-2xl font-bold mb-4">Upscaling that doesn't see your images</h2>
      <p class="text-[color:var(--color-text-mute)] leading-relaxed mb-6">
        Most online AI upscalers upload your image to their GPU farm, run the model there, and stream the result back. Fine for stock photos or memes; less fine for screenshots of internal docs, personal photos, or anything you'd rather not hand to a service. Vexyn runs Swin2SR directly in your browser using WebGPU. Zero requests fire while the model is inferring — verify in DevTools → Network.
      </p>

      <h2 class="text-2xl font-bold mb-4 mt-10">Best use cases</h2>
      <ul class="space-y-2 text-[color:var(--color-text-mute)] mb-6">
        <li><strong class="text-[color:var(--color-text)]">Old digital photos:</strong> 800×600 → 1600×1200 or 3200×2400 with cleaner edges</li>
        <li><strong class="text-[color:var(--color-text)]">Screenshots:</strong> low-res captures → sharp for presentations</li>
        <li><strong class="text-[color:var(--color-text)]">Product photos:</strong> catalogue images at higher resolution</li>
        <li><strong class="text-[color:var(--color-text)]">Web scrapes:</strong> images from sites that only serve smaller versions</li>
      </ul>

      <h2 class="text-2xl font-bold mb-4 mt-10">FAQ</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
            <h3 class="font-semibold mb-2">{f.q}</h3>
            <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed">{f.a}</p>
          </div>
        ))}
      </div>
    </article>
  </div>
</BaseLayout>
