---
import BaseLayout from '../layouts/BaseLayout.astro';
import PdfWatermark from '../components/tools/PdfWatermark.svelte';
import PrivacyNote from '../components/ui/PrivacyNote.astro';
import { SITE } from '../lib/constants';
import { breadcrumbSchema, faqSchema, webAppSchema, combineSchemas } from '../lib/seo';

const title = 'PDF Watermark';
const description = 'Add a text watermark to every page of a PDF — adjustable position, color, size, and opacity. Runs entirely in your browser. No upload, no signup.';

const faqs = [
  { q: 'Can I use an image as the watermark?', a: 'Not yet — this tool supports text watermarks. Image watermarks are on the roadmap. For now, the most common use cases (CONFIDENTIAL, DRAFT, COPY, custom text) are covered.' },
  { q: 'Is the watermark removable?', a: "Visually, no — once embedded in the PDF page content, the text is part of the page like any other drawn element. A determined editor can re-render and remove it, but it isn't trivially deletable in a viewer." },
  { q: 'Does it preserve original text and links?', a: 'Yes. The watermark is drawn on top of existing page content. Selectable text, links, form fields, and bookmarks all stay intact.' },
  { q: 'Is the PDF uploaded?', a: 'No. pdf-lib handles everything in your browser. DevTools → Network confirms zero requests fire while watermarking.' },
];

const schema = combineSchemas(
  webAppSchema({
    name: `${title} — ${SITE.name}`,
    url: `${SITE.url}/pdf-watermark`,
    description,
    features: ['Text watermark with adjustable size, color, opacity', '7 position presets including diagonal', 'Applies to every page', '100% local'],
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'PDF Watermark', url: '/pdf-watermark' },
  ]),
  faqSchema(faqs),
);
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-8">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">PDF Watermark</span>
      </div>
      <h1 class="text-4xl font-bold tracking-tight mb-3">PDF Watermark</h1>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-2xl">
        Add a text watermark to every page — adjustable position, color, size, and opacity. All in your browser.
      </p>
    </header>

    <PrivacyNote />
    <PdfWatermark client:load />

    <article class="prose mt-16 max-w-3xl">
      <h2 class="text-2xl font-bold mb-4">FAQ</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
            <h3 class="font-semibold mb-2">{f.q}</h3>
            <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed">{f.a}</p>
          </div>
        ))}
      </div>
    </article>
  </div>
</BaseLayout>
