---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImageConverter from '../components/tools/ImageConverter.svelte';
import { SITE } from '../lib/constants';
import RelatedReading from '../components/ui/RelatedReading.astro';
import { breadcrumbSchema, faqSchema, webAppSchema, combineSchemas } from '../lib/seo';

const title = 'Image Format Converter';
const description = 'Batch convert JPG, PNG, WebP and AVIF. Pure browser tool — your images never leave your device. No signup, no quota, no upload.';

const faqs = [
  { q: 'Which formats are supported?', a: 'JPG, PNG, WebP and AVIF for output. Any browser-readable image format works as input (JPG, PNG, WebP, GIF, BMP, and HEIC on Safari).' },
  { q: 'Why does AVIF fail in my browser?', a: 'Some browsers (Safari, older Firefox) cannot encode AVIF yet. Use WebP as a near-equivalent fallback — almost the same compression with universal support.' },
  { q: 'Does converting strip my metadata?', a: 'Yes. Canvas re-encoding drops EXIF and other metadata. For sensitive photos that\'s a privacy bonus.' },
];

const schema = combineSchemas(
  webAppSchema({ name: `${title} — ${SITE.name}`, url: `${SITE.url}/image-converter`, description, category: 'MultimediaApplication' }),
  breadcrumbSchema([{ name: 'Home', url: '/' }, { name: title, url: '/image-converter' }]),
  faqSchema(faqs),
);
---

<BaseLayout title={title} description={description} image="/og/image-converter.png" schema={schema}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-8">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">Image Format Converter</span>
      </div>
      <h1 class="text-4xl font-bold tracking-tight mb-3">Image Format Converter</h1>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-2xl">
        Drop a bunch of images, pick the target format, download. JPG ↔ PNG ↔ WebP ↔ AVIF, all in your browser. Adjustable quality. No upload.
      </p>
    </header>

    <ImageConverter client:load />

    <article class="prose mt-16 max-w-3xl">
      <h2 class="text-2xl font-bold mb-4">A pure-browser format converter</h2>
      <p class="text-[color:var(--color-text-mute)] leading-relaxed mb-6">
        Format conversion is one of the most-googled image tasks. Most online converters upload files, quietly cache them, and rate-limit you after a few. This one uses the browser's native Canvas + image encoders — supported formats depend on the browser, but in 2026 Chrome, Edge, Safari and Firefox all handle JPG / PNG / WebP, and Chrome/Edge add AVIF encoding. The work happens locally and there is no quota.
      </p>

      <h2 class="text-2xl font-bold mb-4 mt-10">Which format should I pick?</h2>
      <ul class="space-y-2 text-[color:var(--color-text-mute)] mb-6">
        <li><strong class="text-[color:var(--color-text)]">WebP:</strong> default for the web in 2026. ~25–35% smaller than JPEG. Supported everywhere.</li>
        <li><strong class="text-[color:var(--color-text)]">AVIF:</strong> ~50% smaller than JPEG, but encoding is slower. Use for hero images where bytes matter most.</li>
        <li><strong class="text-[color:var(--color-text)]">JPEG:</strong> universal, ancient. Use for email or when receiver runs old software.</li>
        <li><strong class="text-[color:var(--color-text)]">PNG:</strong> lossless, large. Use for screenshots, UI assets, anything with transparency or sharp edges.</li>
      </ul>

      <RelatedReading articles={[
        { href: '/blog/webp-vs-avif-vs-jpeg-which-format-in-2026', title: 'WebP vs AVIF vs JPEG — which format to use in 2026', description: 'Honest comparison with real numbers, when each format wins, and what to never use them for.' },
      ]} />

      <h2 class="text-2xl font-bold mb-4 mt-10">FAQ</h2>
      <div class="space-y-4">
        <div>
          <h3 class="font-semibold mb-1">Does this also compress?</h3>
          <p class="text-[color:var(--color-text-mute)]">Yes — quality slider applies on JPEG/WebP/AVIF. For dedicated compression with resizing, use the <a class="text-[color:var(--color-brand-400)] hover:underline" href="/image-compressor">Image Compressor</a>.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">AVIF fails in my browser — why?</h3>
          <p class="text-[color:var(--color-text-mute)]">AVIF encoding via Canvas is Chrome/Edge-only as of 2026. Safari and Firefox can decode AVIF but not encode it via the standard API. Use WebP as a near-equivalent fallback.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">Does it strip EXIF?</h3>
          <p class="text-[color:var(--color-text-mute)]">Yes — Canvas re-encoding drops metadata. If you want to keep EXIF, this isn't the right tool.</p>
        </div>
      </div>
    </article>
  </div>
</BaseLayout>
