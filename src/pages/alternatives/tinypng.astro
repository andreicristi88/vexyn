---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../lib/constants';
import { breadcrumbSchema, faqSchema, combineSchemas } from '../../lib/seo';

const title = 'TinyPNG Alternative That Runs in Your Browser';
const description = 'Vexyn is a TinyPNG alternative for image compression that runs entirely in your browser. No upload, no monthly cap, no signup, no paid tier. JPG, PNG, WebP, HEIC supported.';

const faqs = [
  { q: 'Is Vexyn really free, or is there a hidden paid tier?', a: 'Free, forever. There is no paid tier and no plan to add one. Operating cost is just the domain (~$15/year) because every tool runs on your device.' },
  { q: 'Does Vexyn compress as well as TinyPNG?', a: 'For most images, yes. Vexyn uses browser-image-compression at quality 80% by default, which produces JPEG/WebP output very close to TinyPNG\'s lossy compression. You can adjust quality and target format manually.' },
  { q: 'Can I batch compress like TinyPNG\'s paid tier?', a: 'Yes — drop as many files as you want at once, processed in a Web Worker so the UI stays responsive. No 20-image monthly cap.' },
  { q: 'What about TinyPNG\'s API for developers?', a: 'Vexyn doesn\'t offer an API — it\'s a browser tool only. If you need server-side compression at scale, TinyPNG\'s API or a self-hosted tool like sharp/mozjpeg is the right pick. Vexyn fits the "I have these images, compress them now" use case.' },
];

const schema = combineSchemas(
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Alternatives', url: '/alternatives' },
    { name: 'TinyPNG', url: '/alternatives/tinypng' },
  ]),
  faqSchema(faqs),
);
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-10">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <a href="/alternatives" class="hover:text-[color:var(--color-text)]">Alternatives</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">TinyPNG</span>
      </div>

      <p class="text-xs font-medium text-[color:var(--color-text-dim)] uppercase tracking-wider mb-2">Alternative to TinyPNG</p>
      <h1 class="text-4xl font-bold tracking-tight mb-4">A TinyPNG alternative that doesn't upload your images</h1>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-3xl leading-relaxed">
        TinyPNG is a solid image compressor — but every image you compress travels to their servers. Vexyn does the same job in your browser, with no upload, no monthly cap, no account.
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/image-compressor" class="px-5 py-2.5 rounded-lg bg-[color:var(--color-brand-500)] hover:bg-[color:var(--color-brand-600)] text-white font-medium transition-colors inline-flex items-center gap-2">
          Open Image Compressor
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/image-converter" class="px-5 py-2.5 rounded-lg border border-[color:var(--color-border)] hover:border-[color:var(--color-border-strong)] bg-[color:var(--color-surface)] text-[color:var(--color-text)] font-medium transition-colors">
          Or convert formats
        </a>
      </div>
    </header>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-5">Side-by-side</h2>
      <div class="overflow-x-auto rounded-xl border border-[color:var(--color-border)]">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-[color:var(--color-surface)] border-b border-[color:var(--color-border)]">
              <th class="text-left p-4 font-medium text-[color:var(--color-text-mute)]"></th>
              <th class="text-left p-4 font-semibold text-[color:var(--color-brand-400)]">Vexyn</th>
              <th class="text-left p-4 font-semibold">TinyPNG</th>
            </tr>
          </thead>
          <tbody class="text-[color:var(--color-text-mute)]">
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Where files are processed</td>
              <td class="p-4">In your browser</td>
              <td class="p-4">TinyPNG servers (US/EU)</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Files uploaded?</td>
              <td class="p-4 text-[color:var(--color-success)]">No</td>
              <td class="p-4">Yes</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Account required?</td>
              <td class="p-4 text-[color:var(--color-success)]">No</td>
              <td class="p-4">Only for the API / paid plans</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Monthly free limit</td>
              <td class="p-4 text-[color:var(--color-success)]">Unlimited</td>
              <td class="p-4">20 images / month free; paid above</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Batch processing</td>
              <td class="p-4">Yes (limited by your RAM)</td>
              <td class="p-4">Yes — within monthly cap</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Format support</td>
              <td class="p-4">JPG, PNG, WebP, HEIC, AVIF</td>
              <td class="p-4">JPG, PNG, WebP</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Format conversion</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes (separate tool)</td>
              <td class="p-4">No (compression only)</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Quality controls</td>
              <td class="p-4">Quality slider + max dimension</td>
              <td class="p-4">Automatic only</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">EXIF metadata</td>
              <td class="p-4 text-[color:var(--color-success)]">Stripped by default</td>
              <td class="p-4">Preserved</td>
            </tr>
            <tr class="border-b border-[color:var(--color-border)]">
              <td class="p-4 text-[color:var(--color-text)] font-medium">Open source</td>
              <td class="p-4 text-[color:var(--color-success)]">Yes (MIT)</td>
              <td class="p-4">No</td>
            </tr>
            <tr>
              <td class="p-4 text-[color:var(--color-text)] font-medium">Price</td>
              <td class="p-4 text-[color:var(--color-success)]">Free forever</td>
              <td class="p-4">Free tier + paid ($25–$99/mo)</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-[color:var(--color-text-dim)] mt-3">
        Based on publicly available information from <a href="https://tinypng.com" target="_blank" rel="noopener noreferrer" class="hover:text-[color:var(--color-text-mute)] underline">tinypng.com</a> as of June 2026. Both products evolve — verify before relying on a specific number.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">When to pick which</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
          <h3 class="font-semibold text-[color:var(--color-brand-400)] mb-2">Pick Vexyn when…</h3>
          <ul class="text-sm text-[color:var(--color-text-mute)] space-y-1.5 list-disc list-inside">
            <li>Images may contain sensitive data (screenshots, IDs, internal docs)</li>
            <li>You want to compress more than 20 images a month for free</li>
            <li>You need format conversion (HEIC, AVIF)</li>
            <li>You want EXIF metadata removed automatically</li>
            <li>You'd rather not create an account</li>
          </ul>
        </div>
        <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
          <h3 class="font-semibold mb-2">Pick TinyPNG when…</h3>
          <ul class="text-sm text-[color:var(--color-text-mute)] space-y-1.5 list-disc list-inside">
            <li>You need a server-side API for production pipelines</li>
            <li>You're processing thousands of images programmatically</li>
            <li>You want a long-standing brand with paid SLA</li>
            <li>You're working with truly massive files that exceed browser memory</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">FAQ</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
            <h3 class="font-semibold mb-2">{f.q}</h3>
            <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="p-6 rounded-xl bg-gradient-to-br from-[color:var(--color-brand-500)]/10 to-[color:var(--color-accent-500)]/10 border border-[color:var(--color-brand-500)]/30">
      <h2 class="text-xl font-bold mb-2">Try the compressor</h2>
      <p class="text-sm text-[color:var(--color-text-mute)] mb-4">Drop a few images. Confirm nothing is uploaded by opening DevTools → Network.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/image-compressor" class="px-5 py-2.5 rounded-lg bg-[color:var(--color-brand-500)] hover:bg-[color:var(--color-brand-600)] text-white font-medium transition-colors">Open Image Compressor</a>
        <a href="/image-converter" class="px-5 py-2.5 rounded-lg border border-[color:var(--color-border)] hover:border-[color:var(--color-border-strong)] bg-[color:var(--color-surface)] text-[color:var(--color-text)] font-medium transition-colors">Or convert formats →</a>
      </div>
    </section>
  </div>
</BaseLayout>
