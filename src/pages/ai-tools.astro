---
import BaseLayout from '../layouts/BaseLayout.astro';
import HubGrid from '../components/ui/HubGrid.astro';
import { HUBS, toolsForHub } from '../lib/categories';
import { SITE } from '../lib/constants';
import { breadcrumbSchema, combineSchemas, itemListSchema } from '../lib/seo';

const hub = HUBS.ai;
const tools = toolsForHub('ai');

const schema = combineSchemas(
  {
    '@type': 'CollectionPage',
    name: hub.seoTitle,
    url: `${SITE.url}/${hub.slug}`,
    description: hub.seoDescription,
  },
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: hub.label, url: `/${hub.slug}` },
  ]),
  itemListSchema(
    tools.map((t) => ({ name: t.name, url: `/${t.slug}`, description: t.description })),
  ),
);
---

<BaseLayout title={hub.seoTitle} description={hub.seoDescription} schema={schema}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-10">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">{hub.label}</span>
      </div>

      <div class="flex items-center gap-3 mb-4">
        <span class="text-3xl" aria-hidden="true">{hub.icon}</span>
        <h1 class="text-4xl font-bold tracking-tight">{hub.tagline}</h1>
      </div>
      <p class="text-lg text-[color:var(--color-text-mute)] max-w-3xl leading-relaxed">
        {hub.intro}
      </p>
      <p class="mt-4 text-sm text-[color:var(--color-text-mute)]">
        <span class="font-semibold text-[color:var(--color-text)]">{tools.length}</span> AI tools, all on-device, no API.
      </p>
    </header>

    <HubGrid hub="ai" />

    <section class="prose mt-16 max-w-3xl">
      <h2 class="text-2xl font-bold mb-4">How "AI in the browser" works in 2026</h2>
      <p class="text-[color:var(--color-text-mute)] leading-relaxed mb-6">
        Until recently, "AI tool" meant "we send your file to OpenAI / Anthropic / Google / our own GPUs and stream a result back". That's still how most tools work. The alternative — running the model inside your browser tab — only became practical in the last two years with the maturity of <a href="https://www.w3.org/TR/webgpu/" class="text-[color:var(--color-brand-400)] hover:underline" target="_blank" rel="noopener noreferrer">WebGPU</a> and libraries like <a href="https://huggingface.co/docs/transformers.js/" class="text-[color:var(--color-brand-400)] hover:underline" target="_blank" rel="noopener noreferrer">transformers.js</a>. The trade-off is real: a one-time model download (~75-145 MB), variable quality on weak hardware, and limits on model size. The upside is also real: your data never leaves the tab, the tool stays free at any scale, and it works offline after first load.
      </p>

      <h2 class="text-2xl font-bold mb-4 mt-10">Models we ship</h2>
      <ul class="space-y-2 text-[color:var(--color-text-mute)] mb-6">
        <li><strong class="text-[color:var(--color-text)]">OpenAI Whisper</strong> (~75-145 MB) — speech recognition, 99+ languages, used in Audio Transcriber</li>
        <li><strong class="text-[color:var(--color-text)]">BRIA RMBG-1.4</strong> (~85 MB, Apache 2.0) — image background segmentation, used in Background Remover</li>
        <li><strong class="text-[color:var(--color-text)]">Tesseract</strong> (~5-10 MB per language) — OCR, 8 languages, used in PDF OCR</li>
      </ul>

      <h2 class="text-2xl font-bold mb-4 mt-10">Related reading</h2>
      <ul class="text-[color:var(--color-text-mute)] space-y-2">
        <li><a href="/blog/webgpu-explained-ai-in-the-browser" class="text-[color:var(--color-brand-400)] hover:underline">WebGPU explained — running AI in the browser</a></li>
        <li><a href="/blog/how-to-transcribe-audio-for-free-without-uploading" class="text-[color:var(--color-brand-400)] hover:underline">How to transcribe audio for free without uploading</a></li>
        <li><a href="/blog/how-to-remove-background-from-images-without-uploading" class="text-[color:var(--color-brand-400)] hover:underline">How to remove backgrounds without uploading</a></li>
      </ul>
    </section>
  </div>
</BaseLayout>
