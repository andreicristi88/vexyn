---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../lib/constants';
import { breadcrumbSchema, faqSchema, combineSchemas } from '../lib/seo';

const title = 'PDF to Excel — what actually works in 2026';
const description = 'An honest guide. PDF to Excel needs real table extraction, which browsers cannot do well without uploading. Tabula (free, local, open source) and LibreOffice Calc handle this — here is how, plus when Adobe Acrobat is worth the cost.';

const faqs = [
  { q: 'Why doesn\'t Vexyn ship a PDF to Excel converter?', a: 'PDF to Excel needs to detect table boundaries from raw coordinate data — figure out which clusters of text form rows and columns, where cells start and end, which headers belong to which columns. That detection requires either a large trained model (server-side AI) or specialised heuristics that go beyond what a browser tool can reasonably bundle. Vexyn ships only tools that produce quality output in a browser — for PDF to Excel, the honest answer is Tabula or LibreOffice Calc, both of which run locally with better results than any free online service.' },
  { q: 'Is Tabula really free?', a: 'Yes, completely. Tabula is open-source software developed for journalists who needed to extract tabular data from PDFs. Available for Windows, macOS, and Linux at tabula.technology. No paid tier, no signup, no upload.' },
  { q: 'What\'s the difference between Tabula and LibreOffice for this?', a: 'Tabula is purpose-built for table extraction — you draw a box around the table on each page and it produces clean CSV or Excel output. LibreOffice Calc can open a PDF directly but the result is hit-or-miss on tables (often pasting them as positioned text instead of structured cells). Use Tabula when the PDF contains real tabular data you need to crunch. Use LibreOffice for a quick first pass on simple documents.' },
  { q: 'Can I extract tables from a scanned PDF?', a: 'Not directly — scans contain pixels, not text. You need OCR first. Use Vexyn\'s PDF OCR locally to produce a searchable PDF, then run Tabula on the result. Adobe Acrobat Pro combines OCR + table extraction in one step but uploads to their cloud unless you use the desktop app.' },
  { q: 'What about free online PDF to Excel tools?', a: 'Most of them upload your file and use server-side conversion that\'s often worse than Tabula running locally. Some have daily limits (3-5 files for free), and most retain your data for 24-72 hours per their privacy policy. For financial statements, tax data, or anything sensitive, that\'s a trade-off worth making consciously.' },
  { q: 'When is Adobe Acrobat Pro worth paying for?', a: 'For frequent extraction from complex documents with merged cells, nested tables, or pages mixing tables with prose. Acrobat\'s commercial models handle these noticeably better. Pricing around $15-20/mo, with a 7-day free trial that\'s often enough for one-off batches.' },
];

const schema = combineSchemas(
  {
    '@type': 'Article',
    headline: title,
    description,
    url: `${SITE.url}/pdf-to-excel`,
    author: { '@type': 'Organization', name: SITE.name, url: SITE.url },
    publisher: {
      '@type': 'Organization',
      name: SITE.name,
      url: SITE.url,
      logo: { '@type': 'ImageObject', url: `${SITE.url}/logo-512.png` },
    },
    datePublished: '2026-06-22',
    mainEntityOfPage: { '@type': 'WebPage', '@id': `${SITE.url}/pdf-to-excel` },
  },
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'PDF to Excel', url: '/pdf-to-excel' },
  ]),
  faqSchema(faqs),
);
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-10">
      <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-mute)] mb-3">
        <a href="/" class="hover:text-[color:var(--color-text)]">Home</a>
        <span>/</span>
        <span class="text-[color:var(--color-text)]">PDF to Excel</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4 leading-tight">PDF to Excel — what actually works in 2026</h1>
      <p class="text-lg text-[color:var(--color-text-mute)] leading-relaxed">
        An honest guide: why most free online tools mangle your tables, and what to use instead to get clean structured data out of a PDF.
      </p>
    </header>

    <div class="p-5 mb-10 rounded-xl bg-gradient-to-br from-[color:var(--color-brand-500)]/10 to-[color:var(--color-accent-500)]/10 border border-[color:var(--color-brand-500)]/30">
      <p class="text-sm font-semibold uppercase tracking-wider text-[color:var(--color-brand-400)] mb-2">TL;DR</p>
      <ul class="space-y-2 text-sm text-[color:var(--color-text)]">
        <li>• <strong>Best for actual table extraction:</strong> <a href="https://tabula.technology" target="_blank" rel="noopener noreferrer" class="text-[color:var(--color-brand-400)] hover:underline">Tabula</a> — free, open source, you draw a box around the table on each page, get clean CSV or .xlsx.</li>
        <li>• <strong>Quick path for simple documents:</strong> <a href="https://www.libreoffice.org" target="_blank" rel="noopener noreferrer" class="text-[color:var(--color-brand-400)] hover:underline">LibreOffice Calc</a> can open PDFs directly. Hit-or-miss but worth trying first.</li>
        <li>• <strong>Best paid option:</strong> Adobe Acrobat Pro for complex tables (merged cells, nested headers). ~$15-20/mo, 7-day free trial.</li>
        <li>• <strong>What we don't recommend:</strong> free online converters. They upload your file, often produce broken tables, and cap free use.</li>
      </ul>
    </div>

    <article class="prose-vexyn">
      <h2>Why this conversion is hard</h2>
      <p>
        PDF doesn't store tables as tables. It stores text at fixed coordinates. What you see as a row of cells is actually 5 separate text strings positioned at the same y-coordinate. A table-extraction tool has to look at those positions and reconstruct the table — figure out which strings belong to which row, where columns start and end, whether merged cells exist, which row is the header.
      </p>
      <p>
        Getting this right is real work. Free online tools mostly get it wrong on anything beyond the simplest single-column-no-headers tables. Paid services use larger heuristic engines or AI models that handle complex layouts better. Tabula sits in a sweet spot — open source, runs locally, lets you manually mark table boundaries which sidesteps the auto-detection problem entirely.
      </p>

      <h2>The right answer for most cases: Tabula</h2>
      <p>
        <a href="https://tabula.technology" target="_blank" rel="noopener noreferrer">Tabula</a> is built for exactly this. It's open source (MIT-licensed), runs entirely on your machine, and was designed for journalists who needed to extract data from government PDF reports. The workflow:
      </p>
      <ol>
        <li>Download from <a href="https://tabula.technology" target="_blank" rel="noopener noreferrer">tabula.technology</a>. Cross-platform (Windows, macOS, Linux).</li>
        <li>Launch Tabula — it opens a local web interface in your browser.</li>
        <li>Upload your PDF (stays on your machine — the local server processes it).</li>
        <li>For each page with a table, draw a box around the table. Tabula extracts the cells.</li>
        <li>Auto-detect mode also exists for simpler documents.</li>
        <li>Export as CSV, TSV, or .xlsx.</li>
      </ol>
      <p>
        The drawn-box approach is more work than "click convert" but produces far cleaner output. For financial statements, government data, scientific tables, it's the canonical tool.
      </p>

      <h2>Quick path for simple documents: LibreOffice Calc</h2>
      <p>
        If your PDF table is simple (single header row, no merged cells, clean column boundaries), LibreOffice Calc can often open the PDF directly via the OpenOffice import. Quality varies — sometimes you get clean cells, sometimes you get text positioned as cells but not properly structured.
      </p>
      <p>
        Worth trying first because it's a one-step conversion. If the output is garbage, fall back to Tabula.
      </p>

      <h2>When Adobe Acrobat Pro is worth it</h2>
      <p>
        Acrobat's "Export PDF to Excel" feature uses proprietary table-detection models that handle merged cells, nested headers, and tables mixed with prose better than free alternatives. Pricing around $15-20/month, with a 7-day free trial.
      </p>
      <p>Pay for Acrobat if:</p>
      <ul>
        <li>You extract from heavily formatted financial or accounting PDFs weekly</li>
        <li>Tables have merged cells, multi-row headers, or footnotes that need to stay associated</li>
        <li>You need OCR + extraction combined for scanned reports</li>
      </ul>
      <p>
        For one-off batches, the 7-day trial covers it. For occasional use, Tabula does the job for free.
      </p>

      <h2>Special case: scanned PDFs</h2>
      <p>
        Scanned PDFs are images. Tabula and LibreOffice both fail on them because there's no text to extract. You need OCR first.
      </p>
      <p>
        Vexyn ships <a href="/pdf-ocr">PDF OCR</a> that runs Tesseract locally — no upload. The output is a searchable PDF with the original visual layout plus an invisible text layer. Open that searchable PDF in Tabula and the table extraction works the same as for a native PDF.
      </p>
      <p>
        Alternative: Adobe Acrobat Pro does OCR + table extraction in one step. Their desktop app keeps everything local; the cloud version uploads.
      </p>

      <h2>Common mistakes to avoid</h2>
      <ul>
        <li><strong>Using free online converters on sensitive data.</strong> Bank statements, internal financial reports, customer lists — these often go to free online tools. Most retain files 24-72 hours per policy. Even if processing succeeds, your data sits on someone else's infrastructure briefly. For sensitive content, Tabula and LibreOffice keep everything local.</li>
        <li><strong>Trusting auto-detection blindly.</strong> Even Acrobat's best output needs verification. Spot-check totals, check column alignment, confirm header recognition. Wrong data in Excel is worse than no data.</li>
        <li><strong>Forgetting that PDF rounding kills exact math.</strong> Numbers displayed as "1,234.56" in PDF were stored that way as text. Excel imports them as text strings until you explicitly convert them to numbers. Some PDFs hide precision (display 1.23, actual value 1.2347). Watch for that on financial data.</li>
        <li><strong>Mixing scanned and native pages.</strong> Some PDFs are partly scanned, partly native. Tabula handles the native pages cleanly, fails on scanned ones. Run OCR on the whole document first for consistency.</li>
      </ul>

      <h2>What Vexyn does ship for PDF work</h2>
      <p>
        Browser-based PDF tools that work in your tab. None of them convert PDF to Excel directly (for the reasons above) but several support the workflow around it:
      </p>
      <ul>
        <li><a href="/pdf-ocr">PDF OCR</a> — prereq for extracting tables from scanned PDFs</li>
        <li><a href="/pdf-splitter">PDF Splitter</a> — extract only the pages with tables before feeding to Tabula</li>
        <li><a href="/pdf-organizer">PDF Organizer</a> — reorder and delete pages with thumbnails</li>
        <li><a href="/pdf-compressor">PDF Compressor</a> — shrink for sharing or archiving</li>
      </ul>
      <p>
        See the full <a href="/pdf-tools">PDF Tools hub</a> for the complete list.
      </p>

      <h2>Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div class="p-5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-border)]">
            <h3 class="font-semibold mb-2">{f.q}</h3>
            <p class="text-sm text-[color:var(--color-text-mute)] leading-relaxed">{f.a}</p>
          </div>
        ))}
      </div>

      <h2>Bottom line</h2>
      <p>
        For free + local + good results — Tabula. For one-step simple cases — LibreOffice Calc. For complex tables and frequent use — Adobe Acrobat Pro. For free online tools that upload your file — stay away if the data is sensitive.
      </p>
      <p>
        For the other PDF operations Vexyn does well in a browser, browse the <a href="/pdf-tools">PDF Tools hub</a>.
      </p>
    </article>
  </div>
</BaseLayout>

<style>
  .prose-vexyn { color: var(--color-text); font-size: 1rem; line-height: 1.75; }
  .prose-vexyn > * + * { margin-top: 1.25em; }
  .prose-vexyn h2 { font-size: 1.5rem; font-weight: 700; margin-top: 2.5em; margin-bottom: 0.75em; letter-spacing: -0.01em; }
  .prose-vexyn h3 { font-size: 1.15rem; font-weight: 600; margin-top: 2em; margin-bottom: 0.5em; }
  .prose-vexyn p { color: var(--color-text); }
  .prose-vexyn a { color: var(--color-brand-400); text-decoration: none; border-bottom: 1px solid color-mix(in srgb, var(--color-brand-400) 30%, transparent); transition: border-color 0.15s; }
  .prose-vexyn a:hover { border-bottom-color: var(--color-brand-400); }
  .prose-vexyn ul, .prose-vexyn ol { padding-left: 1.5rem; }
  .prose-vexyn li { margin-top: 0.5em; color: var(--color-text-mute); }
  .prose-vexyn ul li { list-style: disc; }
  .prose-vexyn ol li { list-style: decimal; }
  .prose-vexyn strong { color: var(--color-text); font-weight: 600; }
</style>
